---
import "@/styles/global.css"

interface Props {
  title?: string
}

const { title = "SITCON Camp 2026 AI 謎題接龍" } = Astro.props
---

<!doctype html>
<html lang="zh-Hant-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <div class="site-glow site-glow-left"></div>
      <div class="site-glow site-glow-right"></div>
      <div class="site-ribbon" aria-hidden="true"></div>
      <main class="site-main">
        <slot />
      </main>
    </div>
    <script>
      const siteMain = document.querySelector<HTMLElement>(".site-main")
      const BASE_WIDTH = 1320
      const MAX_SCALE = 1.12
      const supportsZoom = typeof CSS !== "undefined" && CSS.supports?.("zoom", "1")
      let scaleFrame: number | null = null

      function updateDesktopScale() {
        scaleFrame = null

        if (!siteMain) return

        const availableWidth = Math.max(window.innerWidth - 32, 0)
        if (!availableWidth) return

        const scale = Math.min(MAX_SCALE, availableWidth / BASE_WIDTH)

        siteMain.style.width = "1280px"
        siteMain.style.maxWidth = "none"
        siteMain.style.transform = ""
        siteMain.style.transformOrigin = ""

        if (supportsZoom) {
          siteMain.style.zoom = scale.toFixed(4)
        } else {
          siteMain.style.zoom = ""
          siteMain.style.transform = `scale(${scale.toFixed(4)})`
          siteMain.style.transformOrigin = "top center"
        }
      }

      function scheduleDesktopScale() {
        if (scaleFrame !== null) cancelAnimationFrame(scaleFrame)
        scaleFrame = requestAnimationFrame(updateDesktopScale)
      }

      scheduleDesktopScale()
      window.addEventListener("resize", scheduleDesktopScale)
      window.addEventListener("load", scheduleDesktopScale)

      if ("fonts" in document) {
        void document.fonts.ready.then(scheduleDesktopScale)
      }

      if ("ResizeObserver" in window && siteMain) {
        const resizeObserver = new ResizeObserver(() => scheduleDesktopScale())
        resizeObserver.observe(siteMain)
      }

      if ("MutationObserver" in window && siteMain) {
        const mutationObserver = new MutationObserver(() => scheduleDesktopScale())
        mutationObserver.observe(siteMain, {
          childList: true,
          subtree: true,
          characterData: true,
          attributes: true,
        })
      }
    </script>
  </body>
</html>
