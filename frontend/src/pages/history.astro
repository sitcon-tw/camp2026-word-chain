---
import Layout from "@/layouts/Layout.astro"
---

<Layout title="對戰紀錄">
  <div class="wc-page">
    <div class="wc-panel p-6 md:p-8">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div>
          <p class="text-sm font-black tracking-[0.28em] text-[#2464ea]">MATCH HISTORY</p>
          <h1 class="mt-2 text-4xl font-black tracking-[-0.04em]">對戰紀錄</h1>
        </div>
        <span id="history-mode" class="badge badge-outline border-[#24272e]/10 bg-white/70 px-4 py-4"
          >讀取中</span
        >
      </div>
      <p id="history-status" class="mt-3 text-sm leading-6 text-[#5f6673]">載入對戰資料中...</p>
    </div>

    <div class="wc-panel p-6 md:p-8">
      <div
        id="history-empty"
        class="rounded-[1.4rem] border border-dashed border-[#24272e]/12 bg-white/50 p-5 text-sm text-[#5f6673]">
        載入中...
      </div>

      <div id="history-list" class="mt-4 grid gap-4"></div>
    </div>
  </div>
</Layout>

<script>
  import { fetchBackend } from "@/utils/socket"

  const ROOM_ID = "sitcon-camp-2026"
  const statusEl = document.getElementById("history-status") as HTMLParagraphElement
  const modeEl = document.getElementById("history-mode") as HTMLSpanElement
  const emptyEl = document.getElementById("history-empty") as HTMLDivElement
  const listEl = document.getElementById("history-list") as HTMLDivElement

  type RoundRecord = {
    gameNumber?: number
    round: number
    matchup: { groupA: number; groupB: number }
    topic: string
    answerA: string
    answerB: string
    scoreA: number
    scoreB: number
    winner: "A" | "B" | "tie"
    reason: string
  }

  type MatchRecord = {
    key: string
    matchup: { groupA: number; groupB: number }
    rounds: RoundRecord[]
  }

  void loadHistory()

  async function loadHistory() {
    try {
      const response = await fetchBackend(`/api/rooms/${encodeURIComponent(ROOM_ID)}`)
      if (response.status === 404) {
        renderEmpty("目前還沒有任何對戰紀錄", "尚無紀錄", false)
        return
      }
      if (!response.ok) {
        renderEmpty("目前無法載入對戰紀錄", "載入失敗", true)
        return
      }

      const data = await response.json()
      const rounds = (data.rounds ?? []) as RoundRecord[]
      const groupedMatches = groupMatches(rounds)
      const modeText = data.matchMode === "test" ? "測試場" : "正式場"
      statusEl.textContent =
        rounds.length === 0 ? "目前還沒有任何對戰紀錄" : `共 ${rounds.length} 回合資料`
      modeEl.textContent = modeText

      if (groupedMatches.length === 0) {
        emptyEl.classList.remove("hidden")
        emptyEl.textContent = "目前還沒有任何回合紀錄。"
        listEl.innerHTML = ""
        return
      }

      emptyEl.classList.add("hidden")
      renderMatches(groupedMatches)
    } catch {
      renderEmpty("目前無法載入對戰紀錄", "載入失敗", true)
    }
  }

  function renderEmpty(statusText: string, modeText: string, isError: boolean) {
    statusEl.textContent = statusText
    modeEl.textContent = modeText
    emptyEl.classList.remove("hidden")
    emptyEl.textContent = isError ? "目前無法連線到後端，請稍後再試。" : "目前還沒有任何回合紀錄。"
    listEl.innerHTML = ""
  }

  function groupMatches(rounds: RoundRecord[]): MatchRecord[] {
    const groupedMatches: MatchRecord[] = []

    for (const round of rounds) {
      if (typeof round.gameNumber === "number") {
        const existingMatch = groupedMatches.find(
          (match) =>
            match.key === `game-${round.gameNumber}` &&
            match.matchup.groupA === round.matchup.groupA &&
            match.matchup.groupB === round.matchup.groupB
        )

        if (existingMatch) {
          existingMatch.rounds.push(round)
        } else {
          groupedMatches.push({
            key: `game-${round.gameNumber}`,
            matchup: round.matchup,
            rounds: [round],
          })
        }
        continue
      }

      const matchupKey = `${round.matchup.groupA}-${round.matchup.groupB}`
      const lastMatch = groupedMatches[groupedMatches.length - 1]
      const lastRound = lastMatch?.rounds[lastMatch.rounds.length - 1]
      const shouldStartNewMatch =
        !lastMatch ||
        lastMatch.key !== matchupKey ||
        !lastRound ||
        round.round <= lastRound.round

      if (shouldStartNewMatch) {
        groupedMatches.push({
          key: `${matchupKey}-${groupedMatches.length + 1}`,
          matchup: round.matchup,
          rounds: [round],
        })
      } else {
        lastMatch.rounds.push(round)
      }
    }

    return groupedMatches
  }

  function renderMatches(matches: MatchRecord[]) {
    listEl.innerHTML = matches
      .map((match, index) => {
        const winsA = match.rounds.filter((round) => round.winner === "A").length
        const winsB = match.rounds.filter((round) => round.winner === "B").length
        const matchWinnerText =
          winsA === winsB
            ? "平手"
            : winsA > winsB
              ? `第 ${match.matchup.groupA} 組勝出`
              : `第 ${match.matchup.groupB} 組勝出`

        return `
          <article class="rounded-[1.6rem] border border-[#24272e]/8 bg-white/72 p-5 shadow-sm">
            <div class="flex flex-wrap items-center justify-between gap-2">
              <h3 class="text-lg font-black">第 ${index + 1} 場：第 ${match.matchup.groupA} 組 vs 第 ${match.matchup.groupB} 組</h3>
              <span class="badge badge-primary border-none">${escapeHtml(matchWinnerText)}</span>
            </div>
            <p class="mt-2 text-sm text-[#5f6673]">共 ${match.rounds.length} 回合，系列比分 ${winsA} : ${winsB}</p>
            <div class="mt-4 grid gap-3">
              ${match.rounds.map(renderRound(match.matchup.groupA, match.matchup.groupB)).join("")}
            </div>
          </article>
        `
      })
      .join("")
  }

  function renderRound(groupA: number, groupB: number) {
    return (round: RoundRecord) => {
      const roundWinnerText =
        round.winner === "tie"
          ? "本回合平手"
          : round.winner === "A"
            ? `第 ${groupA} 組拿下本回合`
            : `第 ${groupB} 組拿下本回合`

      return `
        <section class="rounded-[1.25rem] border border-[#24272e]/8 bg-[#fffaf2] p-4">
          <div class="flex flex-wrap items-center justify-between gap-2">
            <h4 class="font-black">第 ${round.round} 回合</h4>
            <span class="badge badge-outline">${escapeHtml(roundWinnerText)}</span>
          </div>
          <p class="mt-2 text-sm text-[#5f6673]">題目：${escapeHtml(round.topic || "未記錄")}</p>
          <div class="mt-3 grid gap-3 md:grid-cols-2">
            <div class="rounded-[1rem] border border-sky-200 bg-white/72 p-4">
              <div class="text-info text-sm font-black">第 ${groupA} 組</div>
              <div class="mt-1 break-all font-bold">${escapeHtml(round.answerA || "未作答")}</div>
              <div class="mt-2 text-xs text-[#5f6673]">分數：${round.scoreA}</div>
            </div>
            <div class="rounded-[1rem] border border-orange-200 bg-white/72 p-4">
              <div class="text-secondary text-sm font-black">第 ${groupB} 組</div>
              <div class="mt-1 break-all font-bold">${escapeHtml(round.answerB || "未作答")}</div>
              <div class="mt-2 text-xs text-[#5f6673]">分數：${round.scoreB}</div>
            </div>
          </div>
          <p class="mt-3 text-sm">${escapeHtml(round.reason || "無 AI 評語")}</p>
        </section>
      `
    }
  }

  function escapeHtml(value: string) {
    return value.replace(
      /[&<>'"]/g,
      (char) =>
        ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", "'": "&#39;", '"': "&quot;" })[char] ?? char
    )
  }
</script>
