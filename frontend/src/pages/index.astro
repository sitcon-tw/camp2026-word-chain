---
import Layout from "@/layouts/Layout.astro"
import ChevronRightIcon from "~icons/lucide/chevron-right"
---

<Layout title="SITCON Camp 2026 AI 謎題接龍">
  <div class="wc-page wc-page-full">
    <section class="wc-grid-hero">
      <div class="wc-panel wc-panel-distribute p-8 md:p-10">
        <div class="wc-panel-top flex-wrap">
          <div class="flex flex-wrap items-center gap-3">
            <span class="wc-chip">
              <img src="/sitcon-mark.svg" alt="SITCON" class="h-5 w-5" />
              SITCON Camp 2026
            </span>
          </div>
        </div>

        <div class="wc-panel-mid">
          <div>
            <p class="text-sm font-black tracking-[0.3em] text-[#2464ea]">AI WORD CHAIN</p>
            <h1 class="wc-title mt-3">AI 謎題接龍</h1>
          </div>
          <p class="wc-subtitle max-w-2xl">
            以 AI 生成題目為起點，兩隊依序接出五字答案，在同棒次同步交鋒、逐棒推進。<br />
            準備好後，請依目前對戰組別進入場上。
          </p>
        </div>

        <div class="wc-panel-bottom sm:grid-cols-3">
          <div class="wc-list-card p-4">
            <p class="text-xs font-black tracking-[0.2em] text-[#2464ea]">ROUND</p>
            <p id="match-round-label" class="mt-2 text-lg font-black">第 1 場</p>
            <p id="matchup-sub-label" class="mt-2 text-sm leading-6 text-[#5f6673]"
              >第 1 組 vs 第 2 組</p
            >
          </div>
          <div class="wc-list-card p-4">
            <p class="text-xs font-black tracking-[0.2em] text-[#77b55a]">GM</p>
            <p class="mt-2 text-lg font-black">AK</p>
            <p class="mt-2 text-sm leading-6 text-[#5f6673]">關主</p>
          </div>
          <div class="wc-list-card p-4">
            <p class="text-xs font-black tracking-[0.2em] text-[#f69977]">DURATION</p>
            <p class="mt-2 text-lg font-black">25 分鐘</p>
            <p class="mt-2 text-sm leading-6 text-[#5f6673]">單場遊戲時間</p>
          </div>
        </div>
      </div>

      <div class="wc-panel wc-panel-distribute p-6 md:p-8">
        <div class="wc-panel-top">
          <div>
            <p class="text-sm font-black tracking-[0.28em] text-[#2464ea]">PLAYER SIGN-IN</p>
            <h2 class="mt-2 text-3xl font-black tracking-[-0.04em]">選擇你的隊伍</h2>
          </div>
          <img src="/sitcon-mark.svg" alt="SITCON 標誌" class="h-14 w-14 shrink-0 opacity-90" />
        </div>

        <div class="wc-panel-mid">
          <div class="grid gap-3 border-b border-[#24272e]/8 pb-5">
            <p class="text-xs font-black tracking-[0.24em] text-[#2464ea]">OFFICIAL SESSION</p>
            <div
              class="text-[clamp(1.8rem,2.7vw,2.5rem)] font-black tracking-[-0.06em] text-[#24272e]">
              Camp-2026
            </div>
          </div>

          <div class="grid gap-3">
            <button
              id="blue-login-btn"
              class="btn btn-info btn-lg h-auto justify-between rounded-[1.4rem] px-5 py-5 text-left">
              <span class="grid gap-1">
                <span class="text-xs font-black tracking-[0.2em] opacity-80">TEAM A</span>
                <span id="blue-login-label" class="text-xl font-black">A 組</span>
              </span>
              <ChevronRightIcon class="size-6" />
            </button>
            <button
              id="red-login-btn"
              class="btn btn-secondary btn-lg h-auto justify-between rounded-[1.4rem] px-5 py-5 text-left">
              <span class="grid gap-1">
                <span class="text-xs font-black tracking-[0.2em] opacity-80">TEAM B</span>
                <span id="red-login-label" class="text-xl font-black">B 組</span>
              </span>
              <ChevronRightIcon class="size-6" />
            </button>
          </div>
        </div>

        <div class="wc-panel-bottom">
          <div class="rounded-[1.4rem] border border-[#24272e]/8 bg-white/70 p-4">
            <p class="text-sm font-bold text-[#24272e]">登入後流程</p>
            <p class="mt-2 text-sm leading-6 text-[#5f6673]">
              1. 進入等待區確認隊伍
              <br />
              2. 主持人開賽後自動進入作答畫面
              <br />
              3. 兩隊同棒次都提交後，由主持人切換下一棒
            </p>
          </div>

          <span id="error-msg" class="min-h-6 text-sm font-bold text-[#cc4c3f]"></span>
        </div>
      </div>
    </section>
  </div>
</Layout>

<script>
  import { clearSession, getSocket, saveSession } from "@/utils/socket"

  const blueLoginBtn = document.getElementById("blue-login-btn") as HTMLButtonElement
  const redLoginBtn = document.getElementById("red-login-btn") as HTMLButtonElement
  const blueLoginLabel = document.getElementById("blue-login-label") as HTMLSpanElement
  const redLoginLabel = document.getElementById("red-login-label") as HTMLSpanElement
  const matchRoundLabel = document.getElementById("match-round-label") as HTMLParagraphElement
  const matchupSubLabel = document.getElementById("matchup-sub-label") as HTMLParagraphElement
  const errorMsg = document.getElementById("error-msg") as HTMLSpanElement
  const socket = getSocket()
  const ROOM_ID = "sitcon-camp-2026"
  let activeMatchup = { groupA: 1, groupB: 2 }

  function showError(msg: string) {
    if (errorMsg) {
      errorMsg.textContent = msg
    }
  }

  function clearError() {
    if (errorMsg) {
      errorMsg.textContent = ""
    }
  }

  function setPlayerButtonsDisabled(disabled: boolean) {
    if (blueLoginBtn) blueLoginBtn.disabled = disabled
    if (redLoginBtn) redLoginBtn.disabled = disabled
  }

  function applyRoomMeta(data: any) {
    activeMatchup = data.currentMatchup ?? activeMatchup
    matchRoundLabel.textContent = `第 ${Math.max(1, (data.matchupCursor ?? 0) + 1)} 場`
    matchupSubLabel.textContent = `第 ${activeMatchup.groupA} 組 vs 第 ${activeMatchup.groupB} 組`
    blueLoginLabel.textContent = `第 ${activeMatchup.groupA} 組`
    redLoginLabel.textContent = `第 ${activeMatchup.groupB} 組`
  }

  function setDefaultRoomMeta() {
    activeMatchup = { groupA: 1, groupB: 2 }
    matchRoundLabel.textContent = "第 1 場"
    matchupSubLabel.textContent = "第 1 組 vs 第 2 組"
    blueLoginLabel.textContent = `第 ${activeMatchup.groupA} 組`
    redLoginLabel.textContent = `第 ${activeMatchup.groupB} 組`
  }

  function syncRoomMeta() {
    if (!socket.connected) {
      socket.connect()
    }

    socket.emit("room:watch", { roomId: ROOM_ID }, (res: any) => {
      if (!res?.ok) {
        setDefaultRoomMeta()
      }
    })
  }

  async function handleJoin(role: "player" | "host" | "observer", team?: "A" | "B") {
    clearError()

    if (role === "host" || role === "observer") {
      sessionStorage.setItem("wc_role", role)
      sessionStorage.setItem("wc_room_id", ROOM_ID)
      window.location.href = "/sitcon-gm"
      return
    }

    setPlayerButtonsDisabled(true)

    if (!socket.connected) {
      socket.connect()
    }

    socket.once("connect_error", () => {
      showError("無法連線到後端服務，請稍後再試。")
      setPlayerButtonsDisabled(false)
    })

    const roomId = ROOM_ID
    let payload: any = { roomId, role }

    if (role === "player") {
      if (!team) {
        showError("請選擇紅隊或藍隊")
        setPlayerButtonsDisabled(false)
        return
      }

      payload = {
        ...payload,
        team,
        name: `第 ${team === "A" ? activeMatchup.groupA : activeMatchup.groupB} 組`,
      }
    }

    // 發送加入房間事件
    socket.emit("room:join", payload, (res: any) => {
      if (res.ok) {
        if (role === "player") {
          const assignedTeam = res.team === "A" || res.team === "B" ? res.team : null
          saveSession({
            roomId,
            playerId: res.playerId,
            team: assignedTeam,
            seat: null,
            groupNumber:
              assignedTeam === "A"
                ? activeMatchup.groupA
                : assignedTeam === "B"
                  ? activeMatchup.groupB
                  : undefined,
          })
          // 跳轉至等待大廳
          window.location.href = "/room"
        }
      } else {
        showError(`加入失敗: ${res.error}`)
        setPlayerButtonsDisabled(false)
      }
    })
  }

  // 綁定點擊事件
  blueLoginBtn?.addEventListener("click", () => handleJoin("player", "A"))
  redLoginBtn?.addEventListener("click", () => handleJoin("player", "B"))

  // 清除舊連線與 Session
  clearSession()
  sessionStorage.removeItem("wc_role")
  sessionStorage.removeItem("wc_room_id")
  socket.on("room:state", (state: any) => {
    if (state.roomId === ROOM_ID) {
      applyRoomMeta(state)
    }
  })
  socket.on("connect", () => {
    syncRoomMeta()
  })
  socket.on("connect_error", () => {
    setDefaultRoomMeta()
  })
  syncRoomMeta()
</script>
