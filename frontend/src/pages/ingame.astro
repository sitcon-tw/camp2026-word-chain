---
import Layout from "@/layouts/Layout.astro"
import AwardIcon from "~icons/lucide/award"
import HourglassIcon from "~icons/lucide/hourglass"
import PauseIcon from "~icons/lucide/pause"
import PlayIcon from "~icons/lucide/play"
import RefreshCwIcon from "~icons/lucide/refresh-cw"
import ZapIcon from "~icons/lucide/zap"
---

<Layout>
  <div id="player-main-shell" class="contents">
    <!-- Top Bar: Shared info across phases -->
    <div id="shared-top-bar" class="wc-panel mb-5 p-5.5 md:mb-6 md:p-6">
      <div class="grid gap-4 lg:grid-cols-[minmax(0,1fr)_auto_auto] lg:items-center lg:gap-6">
        <div class="min-w-0 text-center lg:text-left">
          <p class="text-xs font-black tracking-[0.24em] text-[#2464ea]" id="top-status-kicker">
            GAME STATUS
          </p>
          <h1
            class="mt-1 text-[clamp(1.25rem,2vw,1.9rem)] font-black tracking-[-0.04em]"
            id="room-info">
            AI 謎題接龍
          </h1>
          <p id="top-status-note" class="mt-1 text-sm leading-6 text-[#5f6673]">
            依照主持節奏進行目前棒次，完成後等待切換下一棒。
          </p>
        </div>

        <div class="hidden lg:flex lg:justify-center">
          <span class="h-14 w-px rounded-full bg-[#24272e]/16"></span>
        </div>

        <div class="justify-self-center lg:justify-self-end">
          <p
            class="text-left text-[11px] font-black tracking-[0.2em] text-[#7b8190]"
            id="top-status-side-label">
            LIVE SCORE
          </p>
          <div
            class="mt-2 grid min-w-[280px] grid-cols-[minmax(5.5rem,1fr)_auto_auto_auto_minmax(5.5rem,1fr)] items-center gap-x-3 whitespace-nowrap">
            <span
              id="header-group-a"
              class="text-info truncate text-right text-[0.9rem] font-black whitespace-nowrap"
              >第 1 組</span
            >
            <span
              id="match-score-a"
              class="text-info min-w-7 text-center font-mono text-[1.15rem] font-black whitespace-nowrap"
              >0</span
            >
            <span class="text-center text-[0.9rem] font-black text-[#5f6673]">:</span>
            <span
              id="match-score-b"
              class="text-secondary min-w-7 text-center font-mono text-[1.15rem] font-black whitespace-nowrap"
              >0</span
            >
            <span
              id="header-group-b"
              class="text-secondary truncate text-left text-[0.9rem] font-black whitespace-nowrap"
              >第 2 組</span
            >
          </div>
        </div>
      </div>
    </div>

    <!-- ================= PHASE 1: ROUND_INTRO ================= -->
    <div
      id="phase-intro"
      class="card bg-base-300 border-primary/20 flex hidden flex-col items-center gap-y-6 border p-8 text-center shadow-2xl">
      <div class="text-primary mt-3 animate-bounce text-5xl font-black tracking-widest"
        >第 <span id="intro-round-num">-</span> 回合即將開始</div
      >
      <div class="divider mx-auto my-0 max-w-md"></div>
      <p class="text-neutral-content/70 text-lg">AI 命題官即將揭曉本次戰局主題：</p>
      <div class="bg-base-100 border-primary/15 max-w-xl rounded-2xl border p-6 shadow-inner">
        <h2 id="intro-topic" class="text-secondary text-2xl font-extrabold tracking-wide"
          >AI 出題生成中...</h2
        >
      </div>

      <!-- Radial Countdown -->
      <div class="mt-4 flex flex-col items-center gap-y-2">
        <div
          id="intro-radial"
          class="radial-progress intro-radial-clean bg-primary/10 text-primary border-primary/20 border-4 font-mono text-3xl font-black shadow-lg"
          style="--value:100; --size:7rem; --thickness: 6px;"
          role="progressbar">
          30s
        </div>
        <span class="text-neutral-content/50 text-xs font-bold">倒數結束後自動開始接龍</span>
      </div>

      <div
        id="intro-host-controls"
        class="hidden w-full max-w-2xl rounded-[1.25rem] border border-[#d97706]/12 bg-white/72 p-4 text-left">
        <div class="flex items-start justify-between gap-3">
          <div>
            <p class="text-xs font-black tracking-[0.22em] text-[#d97706]">INTRO CONTROLS</p>
            <h3 class="mt-1.5 text-lg font-black">開場控制</h3>
          </div>
          <p id="intro-host-status" class="min-h-5 text-right text-xs text-[#5f6673]"></p>
        </div>
        <div class="mt-4 grid gap-2.5 md:grid-cols-3">
          <button
            id="intro-host-pause-btn"
            class="btn btn-warning w-full rounded-full whitespace-nowrap">
            <PauseIcon class="size-4" />暫停
          </button>
          <button
            id="intro-host-resume-btn"
            class="btn btn-success hidden w-full rounded-full whitespace-nowrap">
            <PlayIcon class="size-4" />繼續
          </button>
          <button
            id="intro-host-skip-btn"
            class="btn btn-outline btn-primary w-full rounded-full whitespace-nowrap">
            跳過等待
          </button>
        </div>
      </div>
    </div>

    <!-- ================= PHASE 2: CHAINING (The main gameplay) ================= -->
    <div id="phase-chaining" class="flex hidden flex-col gap-y-2.5">
      <div id="player-chaining-shell" class="contents">
        <!-- Topic Header -->
        <div
          id="staff-topic-card"
          class="card bg-base-300 border-primary/15 flex flex-col items-center border p-3.5 shadow-sm">
          <span class="text-primary/70 mb-1 text-xs font-black tracking-wider uppercase"
            >本次接龍主題</span
          >
          <h2
            id="chaining-topic"
            class="max-w-4xl text-center text-[1.75rem] font-extrabold tracking-wide text-[#24272e]">
            載入中...
          </h2>
        </div>

        <div
          id="host-live-setup-panel"
          class="card bg-base-300 border-primary/15 hidden border p-3.5 shadow-sm">
          <div class="border-primary/12 border-b pb-3 text-center">
            <span class="text-primary/70 mb-1 block text-xs font-black tracking-wider uppercase">
              本次接龍主題
            </span>
            <h2
              id="host-chaining-topic"
              class="mx-auto max-w-4xl text-center text-[1.6rem] font-extrabold tracking-wide text-[#24272e]">
              載入中...
            </h2>
          </div>
          <div class="mt-3 grid w-full gap-3.5 lg:grid-cols-2">
            <div
              class="flex flex-col rounded-[1.25rem] border border-[#d97706]/12 bg-white/72 p-3.5">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <p class="text-xs font-black tracking-[0.22em] text-[#d97706]">LIVE ACTIONS</p>
                  <h3 class="mt-1.5 text-lg font-black">回合控制</h3>
                </div>
                <p id="host-live-status" class="min-h-5 text-right text-xs text-[#5f6673]"></p>
              </div>
              <div class="mt-auto grid gap-2.5 md:grid-cols-3">
                <button
                  id="host-pause-btn"
                  class="btn btn-warning w-full rounded-full whitespace-nowrap">
                  <PauseIcon class="size-4" />暫停
                </button>
                <button
                  id="host-resume-btn"
                  class="btn btn-success hidden w-full rounded-full whitespace-nowrap">
                  <PlayIcon class="size-4" />恢復
                </button>
                <button
                  id="host-force-judge-btn"
                  class="btn btn-error w-full rounded-full whitespace-nowrap">
                  <ZapIcon class="size-4" />強制評審
                </button>
                <button
                  id="host-force-end-game-btn"
                  class="btn btn-outline btn-error w-full rounded-full whitespace-nowrap">
                  結束這組遊戲
                </button>
              </div>
            </div>

            <div
              class="flex flex-col rounded-[1.25rem] border border-[#2464ea]/12 bg-white/72 p-3.5">
              <div>
                <p class="text-xs font-black tracking-[0.22em] text-[#2464ea]">NEXT TOPIC</p>
                <h3 class="mt-1.5 text-lg font-black">指定下一回合題目</h3>
              </div>
              <div class="mt-auto">
                <input
                  id="live-topic-input"
                  class="input input-bordered input-sm w-full border-none"
                  maxlength="60"
                  placeholder="請輸入題目"
                />
                <div class="mt-4 grid gap-2.5 md:grid-cols-2">
                  <button
                    id="live-set-topic-btn"
                    class="btn btn-primary w-full rounded-full whitespace-nowrap">
                    指定題目
                  </button>
                  <button
                    id="live-random-topic-btn"
                    class="btn btn-outline btn-primary w-full rounded-full whitespace-nowrap">
                    隨機題目
                  </button>
                </div>
              </div>
            </div>
          </div>
          <div
            id="host-topic-hint"
            class="mt-3 hidden rounded-[1.2rem] border border-[#2464ea]/14 bg-[#eef4ff] p-4 text-left">
            <p class="text-xs font-black tracking-[0.22em] text-[#2464ea]">HOST HINT</p>
            <p
              id="host-topic-hint-text"
              class="mt-2 text-sm leading-7 whitespace-pre-wrap text-[#24272e]"></p>
          </div>
        </div>

        <div id="player-stage" class="hidden space-y-5 md:space-y-6">
          <div id="player-own-answer" class="card border-primary/16 bg-base-300 border shadow-sm">
            <div class="card-body items-center gap-y-5 p-6 text-center md:p-7">
              <div
                class="border-primary/12 grid w-full max-w-[56rem] items-center gap-5 border-b pb-5 text-center md:grid-cols-[minmax(0,1fr)_auto] md:text-left">
                <div class="min-w-0">
                  <p class="text-primary/70 text-xs font-black tracking-[0.24em] uppercase"
                    >Current Topic</p
                  >
                  <h2
                    id="player-chaining-topic"
                    class="mt-2 text-[1.75rem] font-extrabold tracking-[-0.04em] text-[#24272e]">
                    載入中...
                  </h2>
                </div>
                <div class="flex flex-col items-center justify-center md:items-end md:text-right">
                  <p class="text-primary/70 text-xs font-black tracking-[0.28em] uppercase"
                    >Your Team</p
                  >
                  <h3 id="player-own-title" class="text-[2rem] font-black tracking-[-0.04em]">
                    第 1 組
                  </h3>
                </div>
              </div>
              <div
                id="first-seat-topic-hint"
                class="hidden w-full max-w-[56rem] rounded-[1.2rem] border border-[#2464ea]/14 bg-[#eef4ff] p-4 text-left">
                <p class="text-xs font-black tracking-[0.22em] text-[#2464ea]">FIRST SEAT HINT</p>
                <p
                  id="first-seat-topic-hint-text"
                  class="mt-2 text-sm leading-7 whitespace-pre-wrap text-[#24272e]"></p>
              </div>
              <div id="player-own-chain" class="grid w-full max-w-[56rem] gap-3"></div>
            </div>
          </div>
        </div>

        <div id="player-submit-shell" class="contents">
          <!-- Submission Box (Only active for current player's turn) -->
          <div
            id="submit-panel"
            class="card bg-base-300 border-primary/20 relative flex flex-col items-center justify-center gap-y-3 border p-5 shadow-sm">
            <div
              id="submit-status-banner"
              class="flex items-center gap-x-2 text-sm font-bold text-[#24272e]">
              <HourglassIcon class="text-primary h-4 w-4" />
              <span id="submit-status-text">等待您的棒次作答中...</span>
            </div>

            <!-- Submit form (hidden by default, enabled dynamically) -->
            <div id="submit-action-row" class="hidden w-full">
              <div
                class="mx-auto grid w-full max-w-[56rem] items-center gap-3 md:grid-cols-[1fr_auto] md:items-center">
                <input
                  id="answer-input"
                  type="text"
                  required
                  placeholder="請輸入剛好 5 個字"
                  class="input input-primary input-lg h-14 w-full rounded-[1rem] border-none text-center text-xl font-extrabold tracking-[0.24em] uppercase"
                />
                <button
                  id="submit-btn"
                  class="btn btn-primary btn-lg h-14 rounded-[1rem] px-7 font-black">
                  送出答案
                </button>
              </div>
            </div>
            <div
              id="submit-error"
              class="alert alert-error pointer-events-none absolute right-4 bottom-3 left-4 hidden min-h-0 justify-center px-3 py-2 text-center text-xs font-bold"
              aria-live="polite"></div>
          </div>
        </div>

        <div id="staff-stage" class="grid grid-cols-1 gap-3.5 md:grid-cols-2">
          <!-- Team A -->
          <div id="team-a-answer" class="card bg-base-300 border-info/10 border shadow-xl">
            <div class="card-body p-3.5">
              <div class="border-info/20 mb-2.5 flex items-center justify-between border-b pb-2">
                <span id="team-a-title" class="text-info text-lg font-extrabold">第 1 組</span>
                <div
                  id="timer-team-a"
                  class="badge badge-info hidden animate-pulse py-2.5 font-mono font-bold">--s</div
                >
              </div>
              <div id="chain-list-a" class="space-y-2">
                <!-- Chaining slots -->
              </div>
              <!-- Host skip btn A -->
              <button
                id="skip-team-a-btn"
                class="mt-2.5 hidden w-full rounded-[1rem] border border-[#ef4444]/18 bg-[#ef4444]/6 px-4 py-2 text-sm font-black text-[#c2410c] transition hover:bg-[#ef4444]/10">
                主辦方跳過第 1 組本棒次
              </button>
            </div>
          </div>

          <!-- Team B -->
          <div id="team-b-answer" class="card bg-base-300 border-secondary/10 border shadow-xl">
            <div class="card-body p-3.5">
              <div
                class="border-secondary/20 mb-2.5 flex items-center justify-between border-b pb-2">
                <span id="team-b-title" class="text-secondary text-lg font-extrabold">第 2 組</span>
                <div
                  id="timer-team-b"
                  class="badge badge-secondary hidden animate-pulse py-2.5 font-mono font-bold"
                  >--s</div
                >
              </div>
              <div id="chain-list-b" class="space-y-2">
                <!-- Chaining slots -->
              </div>
              <!-- Host skip btn B -->
              <button
                id="skip-team-b-btn"
                class="mt-2.5 hidden w-full rounded-[1rem] border border-[#ef4444]/18 bg-[#ef4444]/6 px-4 py-2 text-sm font-black text-[#c2410c] transition hover:bg-[#ef4444]/10">
                主辦方跳過第 2 組本棒次
              </button>
            </div>
          </div>
        </div>

      </div>
    </div>
    <!-- ================= PHASE 3: JUDGING ================= -->
    <div
      id="phase-judging"
      class="card bg-base-300 border-primary/20 flex hidden flex-col items-center gap-y-6 border p-12 text-center shadow-2xl">
      <RefreshCwIcon class="text-primary h-16 w-16 animate-spin" />
      <h2 class="text-primary text-3xl font-black tracking-widest">⚖️ 公正 AI 評審分析中</h2>
      <div class="w-full overflow-x-auto">
        <p
          class="mx-auto w-max whitespace-nowrap px-2 text-[clamp(0.95rem,1.35vw,1.125rem)] leading-relaxed text-[#24272e]">
          評審團正依據 <span class="text-secondary font-bold">邏輯性 (25%)</span>、<span
            class="text-secondary font-bold">符合度 (30%)</span
          >、<span class="text-secondary font-bold">完整性 (25%)</span> 及 <span
            class="text-secondary font-bold">創意性 (20%)</span
          > 進行精準打分，並生成繁體中文評語。請耐心等候...
        </p>
      </div>
    </div>

    <!-- ================= PHASE 4: ROUND_RESULT ================= -->
    <div id="phase-result" class="flex hidden flex-col gap-y-6">
      <!-- Winner Banner -->
      <div
        class="card bg-base-300 border-success/20 flex flex-col items-center gap-y-2 border p-6 text-center shadow-xl">
        <AwardIcon class="text-warning h-12 w-12 animate-bounce" />
        <span class="text-warning text-xs font-black tracking-widest uppercase">單回合評審結果</span
        >
        <h2 class="text-4xl font-extrabold tracking-wide" id="result-winner-text">第 1 組獲勝！</h2>
      </div>

      <!-- Scores and Criteria Details -->
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        <!-- Team A Breakdown -->
        <div class="card bg-base-300 border-info/20 border shadow-xl">
          <div class="card-body p-5">
            <div class="border-info/10 mb-4 flex items-center justify-between border-b pb-2">
              <span id="result-group-a-title" class="text-info text-lg font-black">第 1 組</span>
              <span id="result-score-a" class="text-info font-mono text-3xl font-black">0 分</span>
            </div>

            <div class="bg-base-100 border-info/10 mb-4 rounded-2xl border px-4 py-3">
              <p class="text-info text-[11px] font-black tracking-[0.22em]">FULL ANSWER</p>
              <p
                id="result-answer-a"
                class="mt-2 break-all text-base leading-7 font-bold text-[#24272e]">
                載入答案中...
              </p>
            </div>

            <!-- Progress sliders for criteria -->
            <div class="space-y-3" id="criteria-breakdown-a">
              <!-- Dynamically populated -->
            </div>
          </div>
        </div>

        <!-- Team B Breakdown -->
        <div class="card bg-base-300 border-secondary/20 border shadow-xl">
          <div class="card-body p-5">
            <div class="border-secondary/10 mb-4 flex items-center justify-between border-b pb-2">
              <span id="result-group-b-title" class="text-secondary text-lg font-black"
                >第 2 組</span
              >
              <span id="result-score-b" class="text-secondary font-mono text-3xl font-black"
                >0 分</span
              >
            </div>

            <div class="bg-base-100 border-secondary/10 mb-4 rounded-2xl border px-4 py-3">
              <p class="text-secondary text-[11px] font-black tracking-[0.22em]">FULL ANSWER</p>
              <p
                id="result-answer-b"
                class="mt-2 break-all text-base leading-7 font-bold text-[#24272e]">
                載入答案中...
              </p>
            </div>

            <!-- Progress sliders for criteria -->
            <div class="space-y-3" id="criteria-breakdown-b">
              <!-- Dynamically populated -->
            </div>
          </div>
        </div>
      </div>

      <!-- AI Judge Reason bubble -->
      <div class="card bg-base-300 border-primary/10 border p-6 shadow-xl">
        <h3 class="text-primary mb-2 text-sm font-bold tracking-wider uppercase"
          >AI 評審講評與評估緣由</h3
        >
        <blockquote
          id="result-reason"
          class="bg-base-100 border-primary/5 text-neutral rounded-2xl border p-5 text-lg leading-relaxed font-medium italic">
          「載入講評中...」
        </blockquote>
        <span
          id="degraded-badge"
          class="badge badge-warning mt-2 hidden self-start text-[10px] font-bold"
          >⚡ 偵測到 OpenAI 連線異常：已啟用本地 AI 演算法完成容錯打分</span
        >
      </div>

      <!-- Next Actions -->
      <div class="flex justify-center gap-x-4">
        <button
          id="host-next-round-btn"
          class="btn btn-success btn-lg shadow-success/15 hidden px-12 shadow-lg">
          <PlayIcon class="mr-1 h-6 w-6" />
          <span>進入下一回合</span>
        </button>
        <div id="player-waiting-banner" class="alert alert-info max-w-md justify-center font-bold">
          <HourglassIcon class="h-5 w-5 animate-spin" />
          <span>等待主持人開啟下一回合...</span>
        </div>
      </div>
    </div>

    <!-- ================= PHASE 5: MATCH_OVER ================= -->
    <div
      id="phase-matchover"
      class="card bg-base-300 border-warning/30 flex hidden flex-col items-center gap-y-6 border p-10 text-center shadow-2xl">
      <AwardIcon class="text-warning h-20 w-20 animate-pulse" />
      <h2
        class="text-warning text-5xl font-black tracking-widest drop-shadow-lg"
        id="matchover-winner-text">正式場已完成</h2
      >
      <p class="text-neutral text-lg">經過多回合的智慧謎語接龍激烈交鋒，恭喜獲勝組別！</p>

      <div class="divider my-0"></div>

      <div class="flex gap-x-4">
        <button id="end-game-btn" class="btn btn-primary btn-lg hidden px-10">結束遊戲</button>
        <div
          id="matchover-waiting-banner"
          class="alert alert-info max-w-md justify-center font-bold">
          <HourglassIcon class="h-5 w-5 animate-spin" />
          <span>等待主持人結束本場對戰...</span>
        </div>
      </div>
    </div>
  </div>

  <div
    id="host-api-toast"
    class="pointer-events-none fixed right-6 bottom-6 z-50 hidden max-w-[24rem] rounded-[1.2rem] border border-[#cc4c3f]/18 bg-white/95 p-4 text-left shadow-[0_24px_80px_rgba(36,39,46,0.16)] backdrop-blur">
    <p class="text-[11px] font-black tracking-[0.22em] text-[#cc4c3f]">API ERROR</p>
    <p id="host-api-toast-title" class="mt-2 text-sm font-black text-[#24272e]">
      Gemini 評審已切換為備援模式
    </p>
    <p id="host-api-toast-message" class="mt-2 text-sm leading-6 text-[#5f6673]"></p>
  </div>
</Layout>

<script>
  import { clearSession, getSession, getSocket, updateSessionAssignment } from "@/utils/socket"

  // Shared UI Element References
  const roomInfo = document.getElementById("room-info") as HTMLHeadingElement
  const matchScoreA = document.getElementById("match-score-a") as HTMLSpanElement
  const matchScoreB = document.getElementById("match-score-b") as HTMLSpanElement
  const headerGroupA = document.getElementById("header-group-a") as HTMLSpanElement
  const headerGroupB = document.getElementById("header-group-b") as HTMLSpanElement
  const teamATitle = document.getElementById("team-a-title") as HTMLSpanElement
  const teamBTitle = document.getElementById("team-b-title") as HTMLSpanElement
  const resultGroupATitle = document.getElementById("result-group-a-title") as HTMLSpanElement
  const resultGroupBTitle = document.getElementById("result-group-b-title") as HTMLSpanElement

  // Host live setup
  const hostLiveSetupPanel = document.getElementById("host-live-setup-panel") as HTMLElement
  const introHostControls = document.getElementById("intro-host-controls") as HTMLElement
  const introHostPauseBtn = document.getElementById("intro-host-pause-btn") as HTMLButtonElement
  const introHostResumeBtn = document.getElementById("intro-host-resume-btn") as HTMLButtonElement
  const introHostSkipBtn = document.getElementById("intro-host-skip-btn") as HTMLButtonElement
  const introHostStatus = document.getElementById("intro-host-status") as HTMLParagraphElement
  const hostPauseBtn = document.getElementById("host-pause-btn") as HTMLButtonElement
  const hostResumeBtn = document.getElementById("host-resume-btn") as HTMLButtonElement
  const hostForceJudgeBtn = document.getElementById("host-force-judge-btn") as HTMLButtonElement
  const hostForceEndGameBtn = document.getElementById(
    "host-force-end-game-btn"
  ) as HTMLButtonElement
  const hostLiveStatus = document.getElementById("host-live-status") as HTMLParagraphElement
  const liveTopicInput = document.getElementById("live-topic-input") as HTMLInputElement
  const liveSetTopicBtn = document.getElementById("live-set-topic-btn") as HTMLButtonElement
  const liveRandomTopicBtn = document.getElementById("live-random-topic-btn") as HTMLButtonElement

  // Phase Blocks
  const phaseIntro = document.getElementById("phase-intro") as HTMLDivElement
  const phaseChaining = document.getElementById("phase-chaining") as HTMLDivElement
  const phaseJudging = document.getElementById("phase-judging") as HTMLDivElement
  const phaseResult = document.getElementById("phase-result") as HTMLDivElement
  const phaseMatchover = document.getElementById("phase-matchover") as HTMLDivElement

  // Session
  const session = getSession()
  const role = sessionStorage.getItem("wc_role") || (session ? "player" : null)
  const roomId = session?.roomId || sessionStorage.getItem("wc_room_id") || "sitcon-camp-2026"

  if (!role) {
    window.location.href = "/"
  }

  // Connect to socket
  const socket = getSocket()
  if (!socket.connected) {
    socket.connect()
  }

  // Re-establish session or join
  socket.on("room:kicked", () => {
    clearSession()
    sessionStorage.clear()
    window.location.href = "/"
  })

  socket.on("connect", () => {
    if (role === "player" && session) {
      socket.emit("room:rejoin", { roomId, playerId: session.playerId }, (res: any) => {
        if (!res.ok) {
          clearSession()
          window.location.href = "/"
        } else {
          updateSessionAssignment(res.team ?? null, session.groupNumber ?? null)
        }
      })
    } else {
      socket.emit("room:join", { roomId, role }, (res: any) => {
        if (!res.ok) {
          window.location.href = "/"
          return
        }
        if (role === "observer") socket.emit("observer:subscribe", {}, () => {})
      })
    }
  })

  // Host Action Panel Initialization
  if (role === "host" && hostLiveSetupPanel) {
    hostLiveSetupPanel?.classList.remove("hidden")
  }

  // Active timers tracking to prevent overlapping
  let countdownTimer: any = null
  let clearActiveTimer = () => {
    if (countdownTimer) {
      clearInterval(countdownTimer)
      countdownTimer = null
    }
  }

  let submitPending = false
  let activeSubmitRequestId = 0
  let submitAckTimer: ReturnType<typeof setTimeout> | null = null

  function clearSubmitAckTimer() {
    if (submitAckTimer) {
      clearTimeout(submitAckTimer)
      submitAckTimer = null
    }
  }

  function recoverPendingSubmit(message: string) {
    if (!submitPending) return
    submitPending = false
    activeSubmitRequestId = 0
    clearSubmitAckTimer()
    if (submitError) submitError.textContent = message
    if (answerInput) answerInput.disabled = false
    if (submitBtn) submitBtn.disabled = false
  }

  socket.on("presence:update", ({ players }: { players: any[] }) => {
    const currentSession = getSession()
    const me = currentSession ? players.find((p) => p.playerId === currentSession.playerId) : null
    if (me) updateSessionAssignment(me.team ?? null, me.groupNumber ?? null)
  })

  socket.on("disconnect", () => {
    recoverPendingSubmit("連線中斷，答案尚未送出，請重新連線後再試。")
  })

  socket.on("connect_error", () => {
    recoverPendingSubmit("目前無法連線到伺服器，請稍後再試。")
  })

  // Core Room State Listener
  socket.on("room:state", (state: any) => {
    console.log("Active Game Room State:", state)
    clearActiveTimer()

    syncLiveHostForm(state)
    syncGroupLabels(state)

    // 1. Update Global Header Info
    if (matchScoreA) matchScoreA.textContent = String(state.score.A ?? 0)
    if (matchScoreB) matchScoreB.textContent = String(state.score.B ?? 0)

    // Host Pause status sync
    if (role === "host") {
      if (state.paused) {
        hostPauseBtn?.classList.add("hidden")
        hostResumeBtn?.classList.remove("hidden")
      } else {
        hostPauseBtn?.classList.remove("hidden")
        hostResumeBtn?.classList.add("hidden")
      }
    }

    // Hide all phase containers, we'll reveal the active one
    phaseIntro?.classList.add("hidden")
    phaseChaining?.classList.add("hidden")
    phaseJudging?.classList.add("hidden")
    phaseResult?.classList.add("hidden")
    phaseMatchover?.classList.add("hidden")

    // 2. Render State Phase
    switch (state.phase) {
      case "LOBBY":
        if (role === "player") {
          clearSession()
          window.location.href = "/"
        } else {
          window.location.href = "/sitcon-gm"
        }
        break

      case "ROUND_INTRO":
        renderRoundIntro(state)
        break

      case "CHAINING":
        renderChaining(state)
        break

      case "JUDGING":
        hostApiToast?.classList.add("hidden")
        phaseJudging?.classList.remove("hidden")
        break

      case "ROUND_RESULT":
        renderRoundResult(state)
        break

      case "MATCH_OVER":
        renderMatchOver(state)
        break
    }
  })

  // ================= RENDER ROUND_INTRO =================
  const introRoundNum = document.getElementById("intro-round-num") as HTMLSpanElement
  const introTopic = document.getElementById("intro-topic") as HTMLHeadingElement
  const introRadial = document.getElementById("intro-radial") as HTMLDivElement

  function renderRoundIntro(state: any) {
    hostApiToast?.classList.add("hidden")
    phaseIntro?.classList.remove("hidden")
    if (role === "host") {
      introHostControls?.classList.remove("hidden")
      if (state.paused) {
        introHostPauseBtn?.classList.add("hidden")
        introHostResumeBtn?.classList.remove("hidden")
      } else {
        introHostPauseBtn?.classList.remove("hidden")
        introHostResumeBtn?.classList.add("hidden")
      }
    } else {
      introHostControls?.classList.add("hidden")
    }
    if (introRoundNum) introRoundNum.textContent = state.round
    if (introTopic) introTopic.textContent = state.topic || "AI 命題官正在生成謎語主題..."

    if (state.phaseEndsAt && introRadial) {
      const endsAt = state.phaseEndsAt

      const updateTimer = () => {
        const remaining = Math.max(0, endsAt - Date.now())
        const seconds = Math.ceil(remaining / 1000)

        introRadial.textContent = `${seconds}s`

        const introMs = state.rules?.introMs ?? 30000
        const pct = Math.min(100, Math.max(0, (remaining / introMs) * 100))
        introRadial.style.setProperty("--value", String(pct))

        if (remaining <= 0) {
          clearActiveTimer()
        }
      }

      // While paused the server has frozen the deadline — render once, don't tick.
      updateTimer()
      if (!state.paused) {
        countdownTimer = setInterval(updateTimer, 200)
      }
    }
  }

  // ================= RENDER CHAINING =================
  const chainingTopic = document.getElementById("chaining-topic") as HTMLHeadingElement
  const hostChainingTopic = document.getElementById("host-chaining-topic") as HTMLHeadingElement
  const playerChainingTopic = document.getElementById("player-chaining-topic") as HTMLHeadingElement
  const staffTopicCard = document.getElementById("staff-topic-card") as HTMLDivElement
  const chainListA = document.getElementById("chain-list-a") as HTMLDivElement
  const chainListB = document.getElementById("chain-list-b") as HTMLDivElement
  const playerMainShell = document.getElementById("player-main-shell") as HTMLDivElement
  const sharedTopBar = document.getElementById("shared-top-bar") as HTMLDivElement
  const playerChainingShell = document.getElementById("player-chaining-shell") as HTMLDivElement
  const playerSubmitShell = document.getElementById("player-submit-shell") as HTMLDivElement
  const playerStage = document.getElementById("player-stage") as HTMLDivElement
  const staffStage = document.getElementById("staff-stage") as HTMLDivElement
  const playerOwnTitle = document.getElementById("player-own-title") as HTMLHeadingElement
  const playerOwnChain = document.getElementById("player-own-chain") as HTMLDivElement
  const firstSeatTopicHint = document.getElementById("first-seat-topic-hint") as HTMLDivElement
  const firstSeatTopicHintText = document.getElementById(
    "first-seat-topic-hint-text"
  ) as HTMLParagraphElement
  const hostTopicHint = document.getElementById("host-topic-hint") as HTMLDivElement
  const hostTopicHintText = document.getElementById("host-topic-hint-text") as HTMLParagraphElement
  const topStatusKicker = document.getElementById("top-status-kicker") as HTMLParagraphElement
  const topStatusNote = document.getElementById("top-status-note") as HTMLParagraphElement
  const topStatusSideLabel = document.getElementById(
    "top-status-side-label"
  ) as HTMLParagraphElement
  const timerTeamA = document.getElementById("timer-team-a") as HTMLDivElement
  const timerTeamB = document.getElementById("timer-team-b") as HTMLDivElement
  const skipTeamABtn = document.getElementById("skip-team-a-btn") as HTMLButtonElement
  const skipTeamBBtn = document.getElementById("skip-team-b-btn") as HTMLButtonElement
  // Submit block references
  const submitPanel = document.getElementById("submit-panel") as HTMLDivElement
  const submitStatusBanner = document.getElementById("submit-status-banner") as HTMLDivElement
  const submitStatusText = document.getElementById("submit-status-text") as HTMLSpanElement
  const submitActionRow = document.getElementById("submit-action-row") as HTMLDivElement
  const answerInput = document.getElementById("answer-input") as HTMLInputElement
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement
  const submitError = document.getElementById("submit-error") as HTMLDivElement

  const TOPIC_HINTS: Record<string, string> = {
    冒煙測試:
      "在程式和軟件測試中，冒煙測試指初步進行快速測試，了解一個軟體的主要功能是否能夠正常運行。",
    蜜罐:
      "網管人員會故意在網路上架設一個看起來很有價值、防禦力很低的虛擬伺服器，用來吸引黑客前來攻擊。當黑客誤入這個陷阱時，資安人員就可以在不損害真實系統的情況下，偷偷觀察黑客的攻擊手法、收集他們的 IP 和工具。",
    小鴨測試:
      "當程式員遇到解不開的 Bug 時，會試著向一隻放在桌上的軟體橡膠小鴨，逐行解釋自己的程式碼在做什麼。神奇的是，在「向別人解釋」的過程中，大腦會重新理清邏輯，程式員往往講到一半就會自己發現錯誤在哪裡。",
    金絲雀部署:
      "當工程師開發了新功能，他們不會一次開放給所有用戶，而是先更新給極少數（例如 1%）的用戶試用。如果這 1% 的用戶沒有回報重大 Bug，才會逐步推廣到 100%。",
    九頭蛇漏洞:
      "有時候工程師為了修補一個底層的 A 漏洞，改動了核心程式碼，結果導致依賴這個底層的 B、C、D 功能同時崩潰，就像砍了一個頭卻長出更多頭一樣，讓人非常頭痛。",
    義大利麵條程式碼:
      "這通常是因為開發者大量使用不恰當的跳躍語句（如 goto），或者沒有做好模組化，導致邏輯像一盤攪在一起的義大利麵。你想拉出其中一根麵條（改動一個小功能），整盤麵都會跟著動（導致其他幾十個地方一起壞掉）。",
    守門狗定時器:
      "當系統正常運作時，程式必須定時去「餵狗」。如果系統因為當機（死鎖）而停止運作，沒人去餵狗，這隻狗倒數計時到零就會「咬人」——也就是直接強制把整台電腦硬體重啟（Reset），讓設備從當機中恢復。",
    上帝物件:
      "有些工程師喜歡把「所有功能」都寫在同一個檔案、同一個 Class 裡。這個 Class 無所不知、無所不能，既要處理使用者登入、又要控制資料庫、還要繪製介面，就像「上帝」一樣掌控一切。這種代碼極其臃腫，任何人想改動其中一小個功能，都要承受全盤崩潰的風險。",
  }

  function renderChaining(state: any) {
    hostApiToast?.classList.add("hidden")
    phaseChaining?.classList.remove("hidden")
    if (chainingTopic) chainingTopic.textContent = state.topic
    if (hostChainingTopic) hostChainingTopic.textContent = state.topic
    if (playerChainingTopic) playerChainingTopic.textContent = state.topic
    timerTeamA?.classList.add("hidden")
    timerTeamB?.classList.add("hidden")
    const liveSession = getSession()
    const myTeam = role === "player" ? (liveSession?.team ?? null) : null

    playerStage?.classList.toggle("hidden", role !== "player")
    staffStage?.classList.toggle("hidden", role === "player")
    staffTopicCard?.classList.toggle("hidden", role === "player" || role === "host")

    if (role === "player") {
      playerMainShell?.classList.remove("contents")
      playerMainShell?.classList.add(
        "mx-auto",
        "grid",
        "min-h-[100dvh]",
        "w-full",
        "max-w-5xl",
        "content-center",
        "-translate-y-8"
      )
      sharedTopBar?.classList.add("mb-4", "w-full")
      sharedTopBar?.classList.remove("md:mb-6")
      phaseChaining?.classList.add("w-full")
      phaseChaining?.classList.remove("justify-start", "justify-center", "items-center")
      playerChainingShell?.classList.remove("contents")
      playerChainingShell?.classList.add("flex", "w-full", "flex-col", "gap-4")
      playerSubmitShell?.classList.remove("contents")
    } else {
      playerMainShell?.classList.add("contents")
      playerMainShell?.classList.remove(
        "mx-auto",
        "grid",
        "min-h-[100dvh]",
        "w-full",
        "max-w-5xl",
        "content-center",
        "-translate-y-8"
      )
      sharedTopBar?.classList.remove("mb-4", "w-full")
      sharedTopBar?.classList.add("md:mb-6")
      phaseChaining?.classList.remove("w-full")
      phaseChaining?.classList.add("justify-start")
      playerChainingShell?.classList.add("contents")
      playerChainingShell?.classList.remove("flex", "w-full", "flex-col", "gap-4")
      playerSubmitShell?.classList.add("contents")
    }

    if (role === "host") {
      syncHostTopicHint(state.topic)
      if (!state.teams.A.done && !hasSubmittedCurrentSeat(state.teams.A)) {
        skipTeamABtn?.classList.remove("hidden")
      } else {
        skipTeamABtn?.classList.add("hidden")
      }
      if (!state.teams.B.done && !hasSubmittedCurrentSeat(state.teams.B)) {
        skipTeamBBtn?.classList.remove("hidden")
      } else {
        skipTeamBBtn?.classList.add("hidden")
      }
    } else {
      hostTopicHint?.classList.add("hidden")
    }

    // Render team chain blocks
    populateChainList("A", state.teams.A, chainListA, "info", state.rules?.seats ?? 6)
    populateChainList("B", state.teams.B, chainListB, "secondary", state.rules?.seats ?? 6)
    syncPlayerPerspective(state, myTeam)

    if (state.paused) {
      answerInput.setAttribute("disabled", "true")
      submitBtn.disabled = true
      submitBtn.classList.remove("btn-primary")
      submitBtn.classList.add("btn-disabled")
    } else {
      answerInput.removeAttribute("disabled")
      submitBtn.disabled = false
      submitBtn.classList.add("btn-primary")
      submitBtn.classList.remove("btn-disabled")
    }

    // Handle submission panel activation. Players should normally have chosen a team at login.
    if (role === "player" && liveSession) {
      submitPanel?.classList.remove("hidden")
      if (!myTeam) {
        submitStatusBanner?.classList.remove("hidden")
        submitActionRow?.classList.add("hidden")
        submitPanel?.classList.remove("border-success/40", "bg-success/5", "border-error/40", "bg-error/5")
        submitPanel?.classList.add("border-primary/20")
        submitStatusText.textContent = "尚未選擇隊伍，請回首頁重新登入。"
        return
      }

      const currentTeamState = state.teams[myTeam]
      const isMyTurn = !currentTeamState.done && !hasSubmittedCurrentSeat(currentTeamState)

      if (isMyTurn) {
        // Activate Submission Row
        submitStatusBanner?.classList.add("hidden")
        submitActionRow?.classList.remove("hidden")
        submitPanel?.classList.remove("border-error/40", "bg-error/5")
        submitPanel?.classList.add("border-success/40", "bg-success/5")
        submitPanel?.classList.remove("border-primary/20")

        if (answerInput && !state.paused) {
          answerInput.disabled = false
          answerInput.focus()
        }
        if (submitBtn && !state.paused) submitBtn.disabled = false
        if (topStatusKicker) topStatusKicker.textContent = "YOUR TURN"
        if (topStatusNote)
          topStatusNote.textContent = "目前輪到本隊作答，請直接完成這一棒的五字答案並送出。"
      } else {
        // Standby / Wait screen
        submitStatusBanner?.classList.remove("hidden")
        submitActionRow?.classList.add("hidden")
        submitPanel?.classList.remove("border-success/40", "bg-success/5", "border-error/40", "bg-error/5")
        submitPanel?.classList.add("border-primary/20")

        if (currentTeamState.done) {
          submitStatusText.textContent = "恭喜！您小隊的謎語接龍已全數完成！等待評審階段開始中 🏁"
          if (topStatusKicker) topStatusKicker.textContent = "TEAM COMPLETE"
          if (topStatusNote)
            topStatusNote.textContent = "本隊所有棒次已完成，等待另一隊完成後進入評審。"
        } else if (hasSubmittedCurrentSeat(currentTeamState)) {
          submitStatusText.textContent = "本棒次已送出，系統正在切換本隊下一棒。"
          if (topStatusKicker) topStatusKicker.textContent = "WAITING"
          if (topStatusNote) {
            topStatusNote.textContent = "本隊已完成這一棒，系統會依本隊進度直接切到下一棒。"
          }
        } else {
          submitStatusText.textContent = "您小隊正在等待下一棒作答中... ⏳"
          if (topStatusKicker) topStatusKicker.textContent = "STANDBY"
          if (topStatusNote) {
            topStatusNote.textContent = "請留意本隊棒次順序，系統會依本隊進度自動切到你的棒次。"
          }
        }
      }
    } else {
      // Host / Observer
      submitPanel?.classList.add("hidden")
      if (topStatusKicker) topStatusKicker.textContent = "GAME STATUS"
      if (topStatusNote) {
        topStatusNote.textContent = areAllTeamsDone(state)
          ? "兩隊都已完成所有棒次，系統將自動進入評分。"
          : "兩隊會依各自進度獨立作答，全部完成後自動進入評分。"
      }
    }
  }

  function syncPlayerPerspective(state: any, myTeam: "A" | "B" | null) {
    if (role !== "player") return

    const ownTeam = myTeam === "B" ? "B" : "A"
    const ownState = state.teams[ownTeam]
    const ownColor = ownTeam === "A" ? "info" : "secondary"

    if (playerOwnTitle) {
      playerOwnTitle.textContent =
        ownTeam === "A"
          ? (headerGroupA.textContent ?? "第 1 組")
          : (headerGroupB.textContent ?? "第 2 組")
    }

    syncFirstSeatTopicHint(state.topic, ownState)
    populateChainList(ownTeam, ownState, playerOwnChain, ownColor, state.rules?.seats ?? 6)
  }

  function syncFirstSeatTopicHint(topic: string, ownState: any) {
    const hint = TOPIC_HINTS[topic]
    const showHint = Boolean(hint && ownState && !ownState.done && ownState.currentSeat === 1)

    firstSeatTopicHint?.classList.toggle("hidden", !showHint)
    if (showHint && firstSeatTopicHintText) {
      firstSeatTopicHintText.textContent = hint
    }
  }

  function syncHostTopicHint(topic: string) {
    const hint = TOPIC_HINTS[topic]
    const showHint = Boolean(hint)

    hostTopicHint?.classList.toggle("hidden", !showHint)
    if (showHint && hostTopicHintText) {
      hostTopicHintText.textContent = hint
    }
  }

  function populateChainList(
    _teamId: "A" | "B",
    teamState: any,
    container: HTMLDivElement,
    badgeColor: string,
    seats: number
  ) {
    if (!container) return
    container.innerHTML = ""

    for (let i = 1; i <= seats; i++) {
      const val = teamState.segments[i - 1] // segment is index i-1
      const isCurrentActive = !teamState.done && teamState.currentSeat === i

      const card = document.createElement("div")
      card.className = `flex justify-between items-center p-2.5 rounded-xl bg-base-200 border ${
        isCurrentActive ? `border-${badgeColor} bg-${badgeColor}/8` : "border-neutral/20"
      }`

      const seatBadge = `<span class="badge badge-sm badge-${badgeColor} font-black">棒次 ${i}</span>`
      let textSpan = `<span class="text-neutral-content/30 italic text-sm">等待作答...</span>`

      if (val !== undefined) {
        if (val === "") {
          textSpan = `<span class="text-error font-extrabold tracking-widest text-base">［超時未答］</span>`
        } else {
          // If opponent text is empty string (hidden by backend), show block placeholder
          const letters = [...val]
          if (letters.length === 0) {
            textSpan = `<span class="text-neutral-content/40 tracking-[0.24em] font-mono text-sm font-black">▇ ▇ ▇ ▇ ▇</span>`
          } else {
            textSpan = `<span class="text-success tracking-[0.2em] text-base font-black">${val}</span>`
          }
        }
      } else if (isCurrentActive) {
        textSpan = `<span class="text-${badgeColor} font-extrabold text-sm">正在輸入中...</span>`
      }

      card.innerHTML = `
        <div class="flex items-center gap-x-4">
          ${seatBadge}
          ${textSpan}
        </div>
      `

      container.appendChild(card)
    }
  }

  function hasSubmittedCurrentSeat(teamState: any) {
    return (teamState?.segments?.length ?? 0) >= (teamState?.currentSeat ?? 0)
  }

  function areAllTeamsDone(state: any) {
    return Boolean(state?.teams?.A?.done && state?.teams?.B?.done)
  }

  function charCount(text: string) {
    return [...text].length
  }

  function setSubmitError(message: string) {
    if (submitError) {
      submitError.textContent = message
      submitError.classList.remove("hidden")
    }
    submitPanel?.classList.add("border-error/40", "bg-error/5")
    submitPanel?.classList.remove("border-success/40", "bg-success/5")
    answerInput?.classList.add("input-error")
  }

  function clearSubmitError() {
    if (submitError) {
      submitError.textContent = ""
      submitError.classList.add("hidden")
    }
    submitPanel?.classList.remove("border-error/40", "bg-error/5")
    answerInput?.classList.remove("input-error")
  }

  // Answer Submission Event
  submitBtn?.addEventListener("click", performSubmit)
  answerInput?.addEventListener("input", () => {
    clearSubmitError()
  })
  answerInput?.addEventListener("keypress", (e) => {
    if (e.key === "Enter") {
      performSubmit()
    }
  })

  function performSubmit() {
    const text = answerInput.value.trim()
    clearSubmitError()

    if (charCount(text) !== 5) {
      setSubmitError("請輸入剛好 5 個字後再送出。")
      answerInput?.focus()
      return
    }

    if (submitPending) return

    if (!socket.connected) {
      setSubmitError("目前與伺服器中斷連線，請稍後再試。")
      return
    }

    if (answerInput) answerInput.disabled = true
    if (submitBtn) submitBtn.disabled = true
    submitPending = true
    const requestId = Date.now()
    activeSubmitRequestId = requestId
    clearSubmitAckTimer()
    submitAckTimer = setTimeout(() => {
      if (activeSubmitRequestId !== requestId) return
      recoverPendingSubmit("送出逾時，可能是網路異常，請再試一次。")
    }, 8000)

    socket.emit("segment:submit", { text }, (res: any) => {
      if (activeSubmitRequestId !== requestId) return
      submitPending = false
      activeSubmitRequestId = 0
      clearSubmitAckTimer()
      if (res.ok) {
        answerInput.value = ""
        clearSubmitError()
      } else {
        setSubmitError(`提交失敗：${res.error}`)
        if (answerInput) answerInput.disabled = false
        if (submitBtn) submitBtn.disabled = false
      }
    })
  }

  // ================= RENDER ROUND_RESULT =================
  const resultWinnerLine = document.getElementById("result-winner-text") as HTMLHeadingElement
  const resultScoreA = document.getElementById("result-score-a") as HTMLSpanElement
  const resultScoreB = document.getElementById("result-score-b") as HTMLSpanElement
  const resultAnswerA = document.getElementById("result-answer-a") as HTMLParagraphElement
  const resultAnswerB = document.getElementById("result-answer-b") as HTMLParagraphElement
  const criteriaBreakdownA = document.getElementById("criteria-breakdown-a") as HTMLDivElement
  const criteriaBreakdownB = document.getElementById("criteria-breakdown-b") as HTMLDivElement
  const resultReason = document.getElementById("result-reason") as HTMLQuoteElement
  const hostNextRoundBtn = document.getElementById("host-next-round-btn") as HTMLButtonElement
  const playerWaitingBanner = document.getElementById("player-waiting-banner") as HTMLDivElement
  const degradedBadge = document.getElementById("degraded-badge") as HTMLSpanElement
  const hostApiToast = document.getElementById("host-api-toast") as HTMLDivElement
  const hostApiToastTitle = document.getElementById("host-api-toast-title") as HTMLParagraphElement
  const hostApiToastMessage = document.getElementById(
    "host-api-toast-message"
  ) as HTMLParagraphElement

  function renderRoundResult(state: any) {
    phaseResult?.classList.remove("hidden")

    // Extract the last round result
    const lastResult = state.rounds[state.rounds.length - 1]
    if (!lastResult) return

    if (resultWinnerLine) {
      if (lastResult.winner === "tie") {
        resultWinnerLine.className = "text-4xl font-extrabold tracking-wide text-warning"
        resultWinnerLine.textContent = "本局平手！"
      } else {
        const teamName =
          lastResult.winner === "A"
            ? `第 ${lastResult.matchup.groupA} 組`
            : `第 ${lastResult.matchup.groupB} 組`
        resultWinnerLine.className = `text-4xl font-extrabold tracking-wide text-${lastResult.winner === "A" ? "info" : "secondary"}`
        resultWinnerLine.textContent = `🎉 恭喜 ${teamName} 拿下此局！`
      }
    }

    if (resultScoreA) resultScoreA.textContent = `${lastResult.scoreA} 分`
    if (resultScoreB) resultScoreB.textContent = `${lastResult.scoreB} 分`
    if (resultAnswerA) resultAnswerA.textContent = lastResult.answerA || "本隊本回合未留下完整答案。"
    if (resultAnswerB) resultAnswerB.textContent = lastResult.answerB || "本隊本回合未留下完整答案。"

    // Populate Sliders criteria A & B
    populateCriteria(lastResult.breakdown.A, criteriaBreakdownA, "info")
    populateCriteria(lastResult.breakdown.B, criteriaBreakdownB, "secondary")

    // Populate speech reason
    if (resultReason) resultReason.textContent = lastResult.reason || "評審未留下任何評語。"

    // Degradation Mode badge show
    if (lastResult.degraded && degradedBadge) {
      degradedBadge.classList.remove("hidden")
    } else if (degradedBadge) {
      degradedBadge.classList.add("hidden")
    }

    syncHostApiToast(lastResult)

    // Role actions
    if (role === "host") {
      hostNextRoundBtn?.classList.remove("hidden")
      playerWaitingBanner?.classList.add("hidden")
    } else {
      hostNextRoundBtn?.classList.add("hidden")
      playerWaitingBanner?.classList.remove("hidden")
    }
  }

  function syncHostApiToast(lastResult: any) {
    if (role !== "host") {
      hostApiToast?.classList.add("hidden")
      return
    }

    if (!lastResult?.degraded) {
      hostApiToast?.classList.add("hidden")
      return
    }

    const titleByReason: Record<string, string> = {
      quota: "Gemini 額度不足",
      rate_limit: "Gemini 請求過於頻繁",
      timeout: "Gemini 評審逾時",
      auth: "Gemini 驗證失敗",
      invalid_response: "Gemini 回傳格式異常",
      unknown: "Gemini 發生未知錯誤",
    }

    if (hostApiToastTitle) {
      hostApiToastTitle.textContent =
        titleByReason[lastResult.degradedReason ?? "unknown"] ?? "Gemini 評審已切換為備援模式"
    }
    if (hostApiToastMessage) {
      hostApiToastMessage.textContent =
        lastResult.degradedMessage ?? "本回合已改用本地備援評分，請留意 Gemini 狀態。"
    }
    hostApiToast?.classList.remove("hidden")
  }

  function populateCriteria(breakdown: any, container: HTMLDivElement, colorClass: string) {
    if (!container) return
    container.innerHTML = ""

    const items = [
      { key: "邏輯性 (25%)", val: breakdown.logic },
      { key: "符合度 (30%)", val: breakdown.relevance },
      { key: "完整性 (25%)", val: breakdown.completeness },
      { key: "創意性 (20%)", val: breakdown.creativity },
    ]

    for (const item of items) {
      const row = document.createElement("div")
      row.className = "space-y-1"

      row.innerHTML = `
        <div class="flex justify-between items-center text-xs font-bold">
          <span class="text-neutral">${item.key}</span>
          <span class="text-${colorClass}">${item.val} / 100</span>
        </div>
        <progress class="progress progress-${colorClass} w-full h-2" value="${item.val}" max="100"></progress>
      `

      container.appendChild(row)
    }
  }

  // Next round click trigger
  hostNextRoundBtn?.addEventListener("click", () => {
    socket.emit("match:start", {}, (res: any) => {
      if (!res.ok) {
        alert(`無法開啟新一回合：${res.error}`)
      }
    })
  })

  // ================= RENDER MATCH_OVER =================
  const matchoverWinnerText = document.getElementById("matchover-winner-text") as HTMLHeadingElement
  const endGameBtn = document.getElementById("end-game-btn") as HTMLButtonElement
  const matchoverWaitingBanner = document.getElementById(
    "matchover-waiting-banner"
  ) as HTMLDivElement

  function renderMatchOver(state: any) {
    hostApiToast?.classList.add("hidden")
    phaseMatchover?.classList.remove("hidden")
    const matchup = state.currentMatchup ?? state.rounds?.[state.rounds.length - 1]?.matchup
    const groupA = matchup?.groupA ?? 1
    const groupB = matchup?.groupB ?? 2
    const winner =
      state.score.A === state.score.B
        ? "平手"
        : state.score.A > state.score.B
          ? `第 ${groupA} 組獲勝`
          : `第 ${groupB} 組獲勝`
    if (matchoverWinnerText) {
      matchoverWinnerText.textContent = `${winner}，本場對戰結束`
    }
    if (role === "host") {
      endGameBtn?.classList.remove("hidden")
      matchoverWaitingBanner?.classList.add("hidden")
    } else {
      endGameBtn?.classList.add("hidden")
      matchoverWaitingBanner?.classList.remove("hidden")
    }
  }

  function syncGroupLabels(state: any) {
    const matchup = state.currentMatchup ?? state.rounds?.[state.rounds.length - 1]?.matchup
    const groupA = matchup?.groupA ?? 1
    const groupB = matchup?.groupB ?? 2
    headerGroupA.textContent = `第 ${groupA} 組`
    headerGroupB.textContent = `第 ${groupB} 組`
    teamATitle.textContent = `第 ${groupA} 組`
    teamBTitle.textContent = `第 ${groupB} 組`
    resultGroupATitle.textContent = `第 ${groupA} 組`
    resultGroupBTitle.textContent = `第 ${groupB} 組`
    if (playerOwnTitle && role === "player") {
      const liveSession = getSession()
      const myTeam = liveSession?.team ?? "A"
      playerOwnTitle.textContent = myTeam === "A" ? `第 ${groupA} 組` : `第 ${groupB} 組`
    }
    if (topStatusSideLabel) {
      topStatusSideLabel.textContent = role === "player" ? "MATCH SCORE" : "LIVE SCORE"
    }
    roomInfo.textContent =
      state.matchMode === "test"
        ? `測試場對戰：第 ${groupA} 組 vs 第 ${groupB} 組`
        : `正式場對戰：第 ${groupA} 組 vs 第 ${groupB} 組`
  }

  endGameBtn?.addEventListener("click", () => {
    socket.emit("host:end_game", {}, (res: any) => {
      if (!res.ok) {
        alert(`無法結束本場對戰：${res.error}`)
      }
    })
  })

  liveSetTopicBtn?.addEventListener("click", () => {
    const topic = liveTopicInput.value.trim()
    if (!topic) return setLiveHostStatus("請先輸入下一題", true)
    socket.emit("host:set_topic", { topic }, (res: any) => {
      if (!res.ok) setLiveHostStatus(`指定題目失敗：${res.error}`, true)
      else setLiveHostStatus("下一題已指定")
    })
  })

  hostForceEndGameBtn?.addEventListener("click", () => {
    const confirmed = confirm("確認要直接結束這一組遊戲嗎？目前進度將不再繼續。")
    if (!confirmed) return
    socket.emit("host:force_end_game", {}, (res: any) => {
      if (!res.ok) setLiveHostStatus(`無法強制結束本組：${res.error}`, true)
      else setLiveHostStatus("已強制結束這一組遊戲")
    })
  })

  liveRandomTopicBtn?.addEventListener("click", () => {
    socket.emit("host:set_topic", { random: true }, (res: any) => {
      if (!res.ok) setLiveHostStatus(`隨機題目失敗：${res.error}`, true)
      else setLiveHostStatus("已從內建題目池隨機選題")
    })
  })

  function syncLiveHostForm(state: any) {
    if (role !== "host") return
    if (liveTopicInput && document.activeElement !== liveTopicInput) {
      liveTopicInput.value = state.nextTopic ?? ""
    }
  }

  function setLiveHostStatus(message: string, isError = false) {
    if (!hostLiveStatus) return
    hostLiveStatus.textContent = message
    hostLiveStatus.className = isError
      ? "text-error min-h-[1.25rem] text-xs font-bold"
      : "text-success min-h-[1.25rem] text-xs font-bold"
  }

  function setIntroHostStatus(message: string, isError = false) {
    if (!introHostStatus) return
    introHostStatus.textContent = message
    introHostStatus.className = isError
      ? "text-error min-h-[1.25rem] text-xs font-bold"
      : "text-success min-h-[1.25rem] text-xs font-bold"
  }

  // ================= HOST CONTROL ACTIONS EVENT LISTENERS =================
  hostPauseBtn?.addEventListener("click", () => {
    socket.emit("host:pause", {}, (res: any) => {
      if (!res.ok) alert(`暫停失敗：${res.error}`)
    })
  })

  hostResumeBtn?.addEventListener("click", () => {
    socket.emit("host:resume", {}, (res: any) => {
      if (!res.ok) alert(`恢復失敗：${res.error}`)
    })
  })

  hostForceJudgeBtn?.addEventListener("click", () => {
    if (confirm("確認強制提早結束本回合，直接進入 AI 評審打分階段嗎？")) {
      socket.emit("host:force_judge", {}, (res: any) => {
        if (!res.ok) alert(`操作失敗：${res.error}`)
      })
    }
  })

  introHostPauseBtn?.addEventListener("click", () => {
    socket.emit("host:pause", {}, (res: any) => {
      if (!res.ok) setIntroHostStatus(`暫停失敗：${res.error}`, true)
      else setIntroHostStatus("已暫停開場倒數")
    })
  })

  introHostResumeBtn?.addEventListener("click", () => {
    socket.emit("host:resume", {}, (res: any) => {
      if (!res.ok) setIntroHostStatus(`繼續失敗：${res.error}`, true)
      else setIntroHostStatus("已繼續開場倒數")
    })
  })

  introHostSkipBtn?.addEventListener("click", () => {
    socket.emit("host:skip_intro", {}, (res: any) => {
      if (!res.ok) setIntroHostStatus(`跳過失敗：${res.error}`, true)
      else setIntroHostStatus("已跳過等待，進入作答階段")
    })
  })

  skipTeamABtn?.addEventListener("click", () => {
    if (confirm("確認強制超時並跳過 A 小隊當前棒次嗎？")) {
      socket.emit("host:skip_turn", { team: "A" }, (res: any) => {
        if (!res.ok) alert(`操作失敗：${res.error}`)
      })
    }
  })

  skipTeamBBtn?.addEventListener("click", () => {
    if (confirm("確認強制超時並跳過 B 小隊當前棒次嗎？")) {
      socket.emit("host:skip_turn", { team: "B" }, (res: any) => {
        if (!res.ok) alert(`操作失敗：${res.error}`)
      })
    }
  })
</script>
