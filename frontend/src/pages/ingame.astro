---
import Layout from "@/layouts/Layout.astro"
import AwardIcon from "~icons/lucide/award"
import HomeIcon from "~icons/lucide/home"
import HourglassIcon from "~icons/lucide/hourglass"
import PauseIcon from "~icons/lucide/pause"
import PlayIcon from "~icons/lucide/play"
import RefreshCwIcon from "~icons/lucide/refresh-cw"
import ZapIcon from "~icons/lucide/zap"
---

<Layout>
  <!-- Top Bar: Shared info across phases -->
  <div class="card bg-base-300 w-full">
    <div class="card-body flex-row items-center justify-between">
      <span class="badge badge-primary font-bold" id="round-num-badge">Round -</span>
      <h1 class="text-neutral-content text-lg font-bold" id="room-info">AI 謎題接龍</h1>
      <!-- 兩隊分數 -->
      <div class="flex items-center gap-x-2">
        <span id="header-group-a" class="text-info text-sm font-bold">藍隊</span>
        <div class="join">
          <span id="match-score-a" class="btn btn-xs btn-info cursor-default font-mono font-bold"
            >0</span
          >
          <span class="btn btn-xs btn-disabled cursor-default font-mono">:</span>
          <span
            id="match-score-b"
            class="btn btn-xs btn-secondary cursor-default font-mono font-bold">0</span
          >
        </div>
        <span id="header-group-b" class="text-secondary text-sm font-bold">第 2 組</span>
      </div>
      <!--  -->
    </div>
  </div>

  <div id="host-live-setup-panel" class="card bg-base-300 hidden">
    <div class="card-body gap-y-4">
      <div class="flex flex-wrap items-center justify-between gap-2">
        <h2 class="card-title text-primary text-base font-bold">主持即時設定</h2>
        <p id="host-live-status" class="text-neutral-content/50 min-h-5 text-xs"></p>
      </div>

      <div class="flex items-center gap-x-2">
        <button id="host-pause-btn" class="btn btn-xs btn-warning">
          <PauseIcon class="size-4" />暫停
        </button>
        <button id="host-resume-btn" class="btn btn-xs btn-success hidden">
          <PlayIcon class="size-4" />恢復
        </button>
        <button id="host-force-judge-btn" class="btn btn-xs btn-error">
          <ZapIcon class="size-4" />強制評審
        </button>
        <button id="host-force-end-game-btn" class="btn btn-xs btn-outline btn-error">
          結束這組遊戲
        </button>
      </div>

      <div class="grid gap-y-1">
        <label class="text-neutral-content/70 text-xs font-bold">題庫</label>
        <textarea id="live-questions-input" class="textarea w-full text-sm" placeholder="每行一題"
        ></textarea>
        <button id="live-save-questions-btn" class="btn btn-primary btn-sm w-full">儲存題庫</button>
      </div>

      <div class="grid gap-y-1">
        <label class="text-neutral-content/70 text-xs font-bold">指定下一回合題目</label>
        <div class="grid grid-cols-2 gap-x-2 gap-y-1 md:grid-cols-4">
          <input
            id="live-topic-input"
            class="input input-bordered input-sm col-span-2 w-full"
            maxlength="60"
            placeholder="請輸入題目"
          />
          <button id="live-set-topic-btn" class="btn btn-primary btn-sm">指定題目</button>
          <button id="live-random-topic-btn" class="btn btn-outline btn-primary btn-sm"
            >題庫隨機</button
          >
        </div>

        <p id="live-next-topic-label" class="text-neutral-content/60 min-h-5 text-xs"></p>
      </div>

      <div class="grid grid-cols-6 gap-x-2 gap-y-1">
        <label class="form-control">
          <span class="label-text text-[10px] font-bold">開場秒</span>
          <input
            id="live-rule-intro"
            type="number"
            min="3"
            max="300"
            class="input input-bordered input-sm"
          />
        </label>
        <label class="form-control">
          <span class="label-text text-[10px] font-bold">每棒秒</span>
          <input
            id="live-rule-turn"
            type="number"
            min="3"
            max="300"
            class="input input-bordered input-sm"
          />
        </label>
        <label class="form-control">
          <span class="label-text text-[10px] font-bold">結果秒</span>
          <input
            id="live-rule-result"
            type="number"
            min="3"
            max="300"
            class="input input-bordered input-sm"
          />
        </label>
        <label class="form-control">
          <span class="label-text text-[10px] font-bold">棒次</span>
          <input
            id="live-rule-seats"
            type="number"
            min="1"
            max="6"
            class="input input-bordered input-sm"
          />
        </label>
        <label class="form-control">
          <span class="label-text text-[10px] font-bold">勝場</span>
          <input
            id="live-rule-wins"
            type="number"
            min="1"
            max="10"
            class="input input-bordered input-sm"
          />
        </label>
        <button id="live-save-rules-btn" class="btn btn-primary btn-sm mt-auto">套用規則</button>
      </div>
    </div>
  </div>

  <!-- ================= PHASE 1: ROUND_INTRO ================= -->
  <div id="phase-intro" class="card bg-base-300 hidden">
    <div class="card-body flex flex-col justify-center text-center">
      <div class="text-primary text-4xl font-bold tracking-widest"
        >第 <span id="intro-round-num">-</span> 回合即將開始</div
      >
      <div class="divider mx-auto my-0 max-w-md"></div>
      <p class="text-neutral-content/70 text-lg">本次主題為...</p>
      <div class="bg-base-100 rounded-box px-4 py-2">
        <h2 id="intro-topic" class="text-secondary text-2xl font-bold tracking-wide"
          >主題生成中...</h2
        >
      </div>

      <!-- Radial Countdown -->
      <div class="mt-4 flex flex-col items-center gap-y-2">
        <div
          id="intro-radial"
          class="radial-progress bg-primary/10 text-primary border-primary/20 border-4 font-mono text-3xl font-bold"
          style="--value:100; --size:7rem; --thickness: 6px;"
          role="progressbar">
          30s
        </div>
        <span class="text-neutral-content/50 text-xs font-bold">即將開始接龍</span>
      </div>
    </div>
  </div>

  <!-- ================= PHASE 2: CHAINING (The main gameplay) ================= -->
  <div id="phase-chaining" class="flex hidden flex-col gap-y-6">
    <!-- Topic Header -->
    <div class="card bg-base-300">
      <div class="card-body">
        <span class="text-primary text-center text-xs font-bold tracking-wider">本次接龍主題</span>
        <h2
          id="chaining-topic"
          class="text-neutral-content text-center text-2xl font-bold tracking-wide">載入中...</h2
        >
      </div>
    </div>

    <!-- Teams Parallel Chaining Lists -->
    <div class="flex flex-col gap-2 md:flex-row">
      <!-- Team A -->
      <div id="team-a-answer" class="card bg-base-300 flex-1">
        <div class="card-body">
          <div class="flex items-center justify-between">
            <span id="team-a-title" class="text-info text-lg font-bold">藍隊</span>
            <div
              id="timer-team-a"
              class="badge badge-info hidden animate-pulse py-2.5 font-mono font-bold">--s</div
            >
          </div>
          <div id="chain-list-a" class="grid grid-cols-1 gap-2 lg:grid-cols-2">
            <!-- Chaining slots -->
          </div>
          <!-- Host skip btn A -->
          <button id="skip-team-a-btn" class="btn btn-xs btn-outline btn-error hidden w-full"
            >跳過棒次</button
          >
        </div>
      </div>

      <!-- Team B -->
      <div id="team-b-answer" class="card bg-base-300 flex-1">
        <div class="card-body">
          <div class="flex items-center justify-between">
            <span id="team-b-title" class="text-secondary text-lg font-bold">紅隊</span>
            <div id="timer-team-b" class="badge badge-info hidden animate-pulse font-mono font-bold"
              >--s</div
            >
          </div>
          <div id="chain-list-b" class="grid grid-cols-1 gap-2 md:grid-cols-2">
            <!-- Chaining slots -->
          </div>
          <!-- Host skip btn A -->
          <button id="skip-team-b-btn" class="btn btn-xs btn-outline btn-error hidden w-full"
            >跳過棒次</button
          >
        </div>
      </div>
    </div>

    <!-- Submission Box (Only active for current player's turn) -->
    <div
      id="submit-panel"
      class="card bg-base-300 border-primary/20 flex flex-col items-center gap-y-4 border p-6 shadow-xl">
      <div
        id="submit-status-banner"
        class="text-neutral-content flex items-center gap-x-2 text-base font-bold">
        <HourglassIcon class="text-primary h-5 w-5 animate-spin" />
        <span id="submit-status-text">等待您的棒次作答中...</span>
      </div>

      <!-- Submit form (hidden by default, enabled dynamically) -->
      <div id="submit-action-row" class="join hidden w-full max-w-md">
        <input
          id="answer-input"
          type="text"
          required
          maxlength="5"
          placeholder="請輸入剛好 5 個字"
          class="input input-primary join-item input-lg w-full text-center text-2xl font-bold tracking-widest uppercase"
        />
        <button id="submit-btn" class="btn join-item btn-primary btn-lg font-bold">送出</button>
      </div>
      <span id="submit-error" class="text-error min-h-[1.2rem] text-xs font-medium"></span>
    </div>
  </div>

  <!-- ================= PHASE 3: JUDGING ================= -->
  <div
    id="phase-judging"
    class="card bg-base-300 border-primary/20 flex hidden flex-col items-center gap-y-6 border p-12 text-center shadow-2xl">
    <RefreshCwIcon class="text-primary h-16 w-16 animate-spin" />
    <h2 class="text-primary text-3xl font-bold tracking-widest">⚖️ 公正 AI 評審分析中</h2>
    <p class="text-neutral-content/70 max-w-lg leading-relaxed">
      評審團正依據 <span class="text-secondary font-bold">邏輯性 (25%)</span>、<span
        class="text-secondary font-bold">符合度 (30%)</span
      >、<span class="text-secondary font-bold">完整性 (25%)</span> 及 <span
        class="text-secondary font-bold">創意性 (20%)</span
      > 進行精準打分，並生成繁體中文評語。請耐心等候...
    </p>
  </div>

  <!-- ================= PHASE 4: ROUND_RESULT ================= -->
  <div id="phase-result" class="flex hidden flex-col gap-y-6">
    <!-- Winner Banner -->
    <div
      class="card bg-base-300 border-success/20 flex flex-col items-center gap-y-2 border p-6 text-center shadow-xl">
      <AwardIcon class="text-warning h-12 w-12 animate-bounce" />
      <span class="text-warning text-xs font-bold tracking-widest uppercase">單回合評審結果</span>
      <h2 class="text-4xl font-bold tracking-wide" id="result-winner-text">藍隊 獲勝！</h2>
    </div>

    <!-- Scores and Criteria Details -->
    <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
      <!-- Team A Breakdown -->px-10
      <div class="card bg-base-300 border-info/20 border shadow-xl">
        <div class="card-body p-5">
          <div class="border-info/10 mb-4 flex items-center justify-between border-b pb-2">
            <span id="result-group-a-title" class="text-info text-lg font-bold">藍隊</span>
            <span id="result-score-a" class="text-info font-mono text-3xl font-bold">0 分</span>
          </div>

          <!-- Progress sliders for criteria -->
          <div class="space-y-3" id="criteria-breakdown-a">
            <!-- Dynamically populated -->
          </div>
        </div>
      </div>

      <!-- Team B Breakdown -->
      <div class="card bg-base-300 border-secondary/20 border shadow-xl">
        <div class="card-body p-5">
          <div class="border-secondary/10 mb-4 flex items-center justify-between border-b pb-2">
            <span id="result-group-b-title" class="text-secondary text-lg font-bold">紅隊</span>
            <span id="result-score-b" class="text-secondary font-mono text-3xl font-bold">0 分</span
            >
          </div>

          <!-- Progress sliders for criteria -->
          <div class="space-y-3" id="criteria-breakdown-b">
            <!-- Dynamically populated -->
          </div>
        </div>
      </div>
    </div>

    <!-- AI Judge Reason bubble -->
    <div class="card bg-base-300 border-primary/10 border p-6 shadow-xl">
      <h3 class="text-primary mb-2 text-sm font-bold tracking-wider uppercase"
        >AI 評審講評與評估緣由</h3
      >
      <blockquote
        id="result-reason"
        class="bg-base-100 border-primary/5 text-neutral-content/90 rounded-2xl border p-5 text-lg leading-relaxed font-medium italic">
        「載入講評中...」
      </blockquote>
      <span
        id="degraded-badge"
        class="badge badge-warning mt-2 hidden self-start text-[10px] font-bold"
        >⚡ 偵測到 Gemini 連線異常：已啟用本地 AI 演算法完成容錯打分</span
      >
    </div>

    <!-- Next Actions -->
    <div class="flex justify-center gap-x-4">
      <button
        id="host-next-round-btn"
        class="btn btn-success btn-lg shadow-success/15 hidden px-12 shadow-lg">
        <PlayIcon class="mr-1 h-6 w-6" />
        <span>進入下一回合</span>
      </button>
      <div id="player-waiting-banner" class="alert alert-info max-w-md justify-center font-bold">
        <HourglassIcon class="h-5 w-5 animate-spin" />
        <span>等待主持人開啟下一回合...</span>
      </div>
    </div>
  </div>

  <!-- ================= PHASE 5: MATCH_OVER ================= -->
  <div id="phase-matchover" class="card bg-base-300 hidden">
    <div class="card-body justify-center text-center">
      <AwardIcon class="text-warning mx-auto h-20 w-20 animate-pulse" />
      <h2
        class="text-warning text-5xl font-bold tracking-widest drop-shadow-lg"
        id="matchover-winner-text"></h2>
      <p class="text-neutral-content/70 text-lg">經過多回合的智慧謎語接龍激烈交鋒，恭喜獲勝組別！</p
      >

      <div class="divider my-0"></div>

      <div class="flex gap-x-4">
        <button id="back-to-lobby-btn" class="btn btn-primary btn-lg mx-auto"
          ><HomeIcon />返回大廳</button
        >
      </div>
    </div>
  </div>
</Layout>

<script>
  import { clearSession, getSession, getSocket, updateSessionAssignment } from "@/utils/socket"

  // Shared UI Element References
  const roundNumBadge = document.getElementById("round-num-badge") as HTMLSpanElement
  const roomInfo = document.getElementById("room-info") as HTMLHeadingElement
  const matchScoreA = document.getElementById("match-score-a") as HTMLSpanElement
  const matchScoreB = document.getElementById("match-score-b") as HTMLSpanElement
  const headerGroupA = document.getElementById("header-group-a") as HTMLSpanElement
  const headerGroupB = document.getElementById("header-group-b") as HTMLSpanElement
  const teamATitle = document.getElementById("team-a-title") as HTMLSpanElement
  const teamBTitle = document.getElementById("team-b-title") as HTMLSpanElement
  const resultGroupATitle = document.getElementById("result-group-a-title") as HTMLSpanElement
  const resultGroupBTitle = document.getElementById("result-group-b-title") as HTMLSpanElement

  // Host live setup
  const hostLiveSetupPanel = document.getElementById("host-live-setup-panel") as HTMLElement
  const hostPauseBtn = document.getElementById("host-pause-btn") as HTMLButtonElement
  const hostResumeBtn = document.getElementById("host-resume-btn") as HTMLButtonElement
  const hostForceJudgeBtn = document.getElementById("host-force-judge-btn") as HTMLButtonElement
  const hostForceEndGameBtn = document.getElementById(
    "host-force-end-game-btn"
  ) as HTMLButtonElement
  const hostLiveStatus = document.getElementById("host-live-status") as HTMLParagraphElement
  const liveQuestionsInput = document.getElementById("live-questions-input") as HTMLTextAreaElement
  const liveSaveQuestionsBtn = document.getElementById(
    "live-save-questions-btn"
  ) as HTMLButtonElement
  const liveTopicInput = document.getElementById("live-topic-input") as HTMLInputElement
  const liveSetTopicBtn = document.getElementById("live-set-topic-btn") as HTMLButtonElement
  const liveRandomTopicBtn = document.getElementById("live-random-topic-btn") as HTMLButtonElement
  const liveNextTopicLabel = document.getElementById(
    "live-next-topic-label"
  ) as HTMLParagraphElement
  const liveRuleIntro = document.getElementById("live-rule-intro") as HTMLInputElement
  const liveRuleTurn = document.getElementById("live-rule-turn") as HTMLInputElement
  const liveRuleResult = document.getElementById("live-rule-result") as HTMLInputElement
  const liveRuleSeats = document.getElementById("live-rule-seats") as HTMLInputElement
  const liveRuleWins = document.getElementById("live-rule-wins") as HTMLInputElement
  const liveSaveRulesBtn = document.getElementById("live-save-rules-btn") as HTMLButtonElement

  // Phase Blocks
  const phaseIntro = document.getElementById("phase-intro") as HTMLDivElement
  const phaseChaining = document.getElementById("phase-chaining") as HTMLDivElement
  const phaseJudging = document.getElementById("phase-judging") as HTMLDivElement
  const phaseResult = document.getElementById("phase-result") as HTMLDivElement
  const phaseMatchover = document.getElementById("phase-matchover") as HTMLDivElement

  // Session
  const session = getSession()
  const role = sessionStorage.getItem("wc_role") || (session ? "player" : null)
  const roomId = session?.roomId || sessionStorage.getItem("wc_room_id") || "sitcon-camp-2026"

  if (!role) {
    window.location.href = "/"
  }

  // Connect to socket
  const socket = getSocket()
  if (!socket.connected) {
    socket.connect()
  }

  // Re-establish session or join
  socket.on("room:kicked", () => {
    clearSession()
    sessionStorage.clear()
    window.location.href = "/"
  })

  socket.on("connect", () => {
    if (role === "player" && session) {
      socket.emit("room:rejoin", { roomId, playerId: session.playerId }, (res: any) => {
        if (!res.ok) {
          clearSession()
          window.location.href = "/"
        } else {
          updateSessionAssignment(res.team ?? null, session.groupNumber ?? null)
        }
      })
    } else {
      socket.emit("room:join", { roomId, role }, (res: any) => {
        if (!res.ok) {
          window.location.href = "/"
          return
        }
        if (role === "observer") socket.emit("observer:subscribe", {}, () => {})
      })
    }
  })

  // Host Action Panel Initialization
  if (role === "host" && hostLiveSetupPanel) {
    hostLiveSetupPanel?.classList.remove("hidden")
  }

  // Active timers tracking to prevent overlapping
  let countdownTimer: any = null
  let liveRulesDirty = false
  let liveQuestionsDirty = false

  let clearActiveTimer = () => {
    if (countdownTimer) {
      clearInterval(countdownTimer)
      countdownTimer = null
    }
  }

  socket.on("presence:update", ({ players }: { players: any[] }) => {
    const currentSession = getSession()
    const me = currentSession ? players.find((p) => p.playerId === currentSession.playerId) : null
    if (me) updateSessionAssignment(me.team ?? null, me.groupNumber ?? null)
  })

  // Core Room State Listener
  socket.on("room:state", (state: any) => {
    console.log("Active Game Room State:", state)
    clearActiveTimer()

    syncLiveHostForm(state)
    syncGroupLabels(state)

    // 1. Update Global Header Info
    if (roundNumBadge) roundNumBadge.textContent = `Round ${state.round}`
    if (matchScoreA) matchScoreA.textContent = String(state.score.A ?? 0)
    if (matchScoreB) matchScoreB.textContent = String(state.score.B ?? 0)

    // Host Pause status sync
    if (role === "host") {
      if (state.paused) {
        hostPauseBtn?.classList.add("hidden")
        hostResumeBtn?.classList.remove("hidden")
      } else {
        hostPauseBtn?.classList.remove("hidden")
        hostResumeBtn?.classList.add("hidden")
      }
    }

    // Hide all phase containers, we'll reveal the active one
    phaseIntro?.classList.add("hidden")
    phaseChaining?.classList.add("hidden")
    phaseJudging?.classList.add("hidden")
    phaseResult?.classList.add("hidden")
    phaseMatchover?.classList.add("hidden")

    // 2. Render State Phase
    switch (state.phase) {
      case "LOBBY":
        if (role === "player") {
          clearSession()
          window.location.href = "/"
        } else {
          window.location.href = "/room"
        }
        break

      case "ROUND_INTRO":
        renderRoundIntro(state)
        break

      case "CHAINING":
        renderChaining(state)
        break

      case "JUDGING":
        phaseJudging?.classList.remove("hidden")
        break

      case "ROUND_RESULT":
        renderRoundResult(state)
        break

      case "MATCH_OVER":
        renderMatchOver(state)
        break
    }
  })

  // ================= RENDER ROUND_INTRO =================
  const introRoundNum = document.getElementById("intro-round-num") as HTMLSpanElement
  const introTopic = document.getElementById("intro-topic") as HTMLHeadingElement
  const introRadial = document.getElementById("intro-radial") as HTMLDivElement

  function renderRoundIntro(state: any) {
    phaseIntro?.classList.remove("hidden")
    if (introRoundNum) introRoundNum.textContent = state.round
    if (introTopic) introTopic.textContent = state.topic || "正在生成主題..."

    if (state.phaseEndsAt && introRadial) {
      const endsAt = state.phaseEndsAt

      const updateTimer = () => {
        const remaining = Math.max(0, endsAt - Date.now())
        const seconds = Math.ceil(remaining / 1000)

        introRadial.textContent = seconds.toString()

        const introMs = state.rules?.introMs ?? 30000
        const pct = Math.min(100, Math.max(0, (remaining / introMs) * 100))
        introRadial.style.setProperty("--value", String(pct))

        if (remaining <= 0) {
          clearActiveTimer()
        }
      }

      // While paused the server has frozen the deadline — render once, don't tick.
      updateTimer()
      if (!state.paused) {
        countdownTimer = setInterval(updateTimer, 200)
      }
    }
  }

  // ================= RENDER CHAINING =================
  const chainingTopic = document.getElementById("chaining-topic") as HTMLHeadingElement
  const chainListA = document.getElementById("chain-list-a") as HTMLDivElement
  const chainListB = document.getElementById("chain-list-b") as HTMLDivElement
  const timerTeamA = document.getElementById("timer-team-a") as HTMLDivElement
  const timerTeamB = document.getElementById("timer-team-b") as HTMLDivElement
  const skipTeamABtn = document.getElementById("skip-team-a-btn") as HTMLButtonElement
  const skipTeamBBtn = document.getElementById("skip-team-b-btn") as HTMLButtonElement
  const answerDivA = document.getElementById("team-a-answer") as HTMLDivElement
  const answerDivB = document.getElementById("team-b-answer") as HTMLDivElement

  // Submit block references
  const submitPanel = document.getElementById("submit-panel") as HTMLDivElement
  const submitStatusBanner = document.getElementById("submit-status-banner") as HTMLDivElement
  const submitStatusText = document.getElementById("submit-status-text") as HTMLSpanElement
  const submitActionRow = document.getElementById("submit-action-row") as HTMLDivElement
  const answerInput = document.getElementById("answer-input") as HTMLInputElement
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement
  const submitError = document.getElementById("submit-error") as HTMLSpanElement

  function renderChaining(state: any) {
    phaseChaining?.classList.remove("hidden")
    if (chainingTopic) chainingTopic.textContent = state.topic

    // Show host skipping control
    if (role === "host") {
      skipTeamABtn?.classList.remove("hidden")
      skipTeamBBtn?.classList.remove("hidden")
    }

    // Render team chain blocks
    populateChainList("A", state.teams.A, chainListA, "info", state.rules?.seats ?? 6)
    populateChainList("B", state.teams.B, chainListB, "secondary", state.rules?.seats ?? 6)

    // Sync Turn timers (20s TurnMs is standard) — freeze while paused
    syncTurnTimer("A", state.teams.A, timerTeamA, state.paused)
    syncTurnTimer("B", state.teams.B, timerTeamB, state.paused)

    if (state.paused) {
      answerInput.setAttribute("disabled", "true")
      submitBtn.disabled = true
      submitBtn.classList.remove("btn-primary")
      submitBtn.classList.add("btn-disabled")
    } else {
      answerInput.removeAttribute("disabled")
      submitBtn.disabled = false
      submitBtn.classList.add("btn-primary")
      submitBtn.classList.remove("btn-disabled")
    }

    // Handle submission panel activation. Players should normally have chosen a team at login.
    const liveSession = getSession()
    if (role === "player" && liveSession) {
      const myTeam = liveSession.team

      if (!myTeam) {
        submitStatusBanner?.classList.remove("hidden")
        submitActionRow?.classList.add("hidden")
        submitPanel?.classList.remove("border-success/40", "bg-success/5")
        submitPanel?.classList.add("border-primary/20")
        submitStatusText.textContent = "尚未選擇隊伍，請回首頁重新登入。"
        return
      }

      // 移除非自己隊伍的作答情況
      if (myTeam === "A") answerDivB?.remove()
      else answerDivA?.remove()

      const currentTeamState = state.teams[myTeam]
      const isMyTurn = !currentTeamState.done

      if (isMyTurn) {
        // Activate Submission Row
        submitStatusBanner?.classList.add("hidden")
        submitActionRow?.classList.remove("hidden")
        submitPanel?.classList.add("border-success/40", "bg-success/5")
        submitPanel?.classList.remove("border-primary/20")

        if (answerInput && !state.paused) {
          answerInput.disabled = false
          answerInput.focus()
        }
        if (submitBtn && !state.paused) submitBtn.disabled = false
      } else {
        // Standby / Wait screen
        submitStatusBanner?.classList.remove("hidden")
        submitActionRow?.classList.add("hidden")
        submitPanel?.classList.remove("border-success/40", "bg-success/5")
        submitPanel?.classList.add("border-primary/20")

        if (currentTeamState.done) {
          submitStatusText.textContent =
            "恭喜！您小隊的謎語接龍已全數完成，請稍待對方隊伍完成接龍。"
        } else {
          submitStatusText.textContent = "您小隊正在等待下一棒作答中... ⏳"
        }
      }
    } else {
      // Host / Observer
      submitStatusBanner?.classList.remove("hidden")
      submitActionRow?.classList.add("hidden")
      submitStatusText.textContent = "接龍比賽進行中，你可透過上方的界面查看目前進度，並控制系統。"
    }
  }

  function populateChainList(
    _teamId: "A" | "B",
    teamState: any,
    container: HTMLDivElement,
    badgeColor: string,
    seats: number
  ) {
    if (!container) return
    container.innerHTML = ""

    for (let i = 1; i <= seats; i++) {
      const val = teamState.segments[i - 1] // segment is index i-1
      const isCurrentActive = !teamState.done && teamState.currentSeat === i

      const card = document.createElement("div")
      card.className = `flex justify-between items-center p-3 rounded-xl bg-base-200 border ${
        isCurrentActive
          ? `border-${badgeColor} bg-${badgeColor}/10 animate-pulse`
          : "border-neutral/20"
      }`

      const seatBadge = `<span class="badge badge-sm badge-${badgeColor} font-bold">棒次 ${i}</span>`
      let textSpan = `<span class="text-neutral-content/30 italic text-sm">等待作答...</span>`

      if (val !== undefined) {
        if (val === "") {
          textSpan = `<span class="text-error font-bold tracking-widest text-base">［超時未答］</span>`
        } else {
          // If opponent text is empty string (hidden by backend), show block placeholder
          const letters = [...val]
          if (letters.length === 0) {
            textSpan = `<span class="text-neutral-content/40 tracking-[0.3em] font-mono text-base font-bold">▇ ▇ ▇ ▇ ▇</span>`
          } else {
            textSpan = `<span class="text-success tracking-[0.25em] text-lg font-bold">${val}</span>`
          }
        }
      } else if (isCurrentActive) {
        textSpan = `<span class="text-${badgeColor} font-bold animate-pulse text-sm">正在輸入中...</span>`
      }

      card.innerHTML = `
        <div class="flex items-center gap-x-4">
          ${seatBadge}
          ${textSpan}
        </div>
      `

      container.appendChild(card)
    }
  }

  function syncTurnTimer(
    teamId: "A" | "B",
    teamState: any,
    timerBadge: HTMLDivElement,
    paused: boolean
  ) {
    if (!timerBadge) return

    if (teamState.done || !teamState.turnEndsAt) {
      timerBadge.classList.add("hidden")
      return
    }

    timerBadge.classList.remove("hidden")
    const endsAt = teamState.turnEndsAt

    // Setup a mini animation frame/interval specifically for turn countdowns
    const update = () => {
      const rem = Math.max(0, endsAt - Date.now())
      const sec = Math.ceil(rem / 1000)
      timerBadge.textContent = paused ? `${sec}s（暫停）` : `${sec}s 剩餘`

      if (paused) {
        timerBadge.className = "badge badge-warning py-2.5 text-xs font-mono font-bold"
      } else if (rem <= 5000) {
        timerBadge.className = "badge badge-error py-2.5 text-xs font-mono font-bold animate-pulse"
      } else {
        timerBadge.className = `badge badge-${teamId === "A" ? "info" : "secondary"} py-2.5 text-xs font-mono font-bold animate-pulse`
      }
    }

    // While paused the deadline is frozen on the server — render once and do NOT tick.
    update()
    if (paused) return

    // We can run these concurrently in a local animation or let the parent update handling cover it
    const localTimer = setInterval(update, 500)
    // Bind to the countdownTimer clear sequence
    const origClear = clearActiveTimer
    clearActiveTimer = () => {
      clearInterval(localTimer)
      origClear()
    }
  }

  // Answer Submission Event
  submitBtn?.addEventListener("click", performSubmit)
  answerInput?.addEventListener("keypress", (e) => {
    if (e.key === "Enter") {
      performSubmit()
    }
  })

  function performSubmit() {
    if (submitError) submitError.textContent = ""
    const text = answerInput.value.trim()

    if ([...text].length !== 5) {
      if (submitError) submitError.textContent = "答案必須剛好是 5 個字！"
      return
    }

    if (answerInput) answerInput.disabled = true
    if (submitBtn) submitBtn.disabled = true

    socket.emit("segment:submit", { text }, (res: any) => {
      if (res.ok) {
        answerInput.value = ""
      } else {
        if (submitError) submitError.textContent = `答案送出失敗：${res.error}`
        if (answerInput) answerInput.disabled = false
        if (submitBtn) submitBtn.disabled = false
      }
    })
  }

  // ================= RENDER ROUND_RESULT =================
  const resultWinnerLine = document.getElementById("result-winner-text") as HTMLHeadingElement
  const resultScoreA = document.getElementById("result-score-a") as HTMLSpanElement
  const resultScoreB = document.getElementById("result-score-b") as HTMLSpanElement
  const criteriaBreakdownA = document.getElementById("criteria-breakdown-a") as HTMLDivElement
  const criteriaBreakdownB = document.getElementById("criteria-breakdown-b") as HTMLDivElement
  const resultReason = document.getElementById("result-reason") as HTMLQuoteElement
  const hostNextRoundBtn = document.getElementById("host-next-round-btn") as HTMLButtonElement
  const playerWaitingBanner = document.getElementById("player-waiting-banner") as HTMLDivElement
  const degradedBadge = document.getElementById("degraded-badge") as HTMLSpanElement

  function renderRoundResult(state: any) {
    phaseResult?.classList.remove("hidden")

    // Extract the last round result
    const lastResult = state.rounds[state.rounds.length - 1]
    if (!lastResult) return

    if (resultWinnerLine) {
      if (lastResult.winner === "tie") {
        resultWinnerLine.className = "text-4xl font-bold tracking-wide text-warning"
        resultWinnerLine.textContent = "本局平手！"
      } else {
        const teamName = lastResult.winner === "A" ? "藍隊" : "紅隊"
        resultWinnerLine.className = `text-4xl font-bold tracking-wide text-${lastResult.winner === "A" ? "info" : "secondary"}`
        resultWinnerLine.textContent = `恭喜 ${teamName} 拿下此局！`
      }
    }

    if (resultScoreA) resultScoreA.textContent = `${lastResult.scoreA} 分`
    if (resultScoreB) resultScoreB.textContent = `${lastResult.scoreB} 分`

    // Populate Sliders criteria A & B
    populateCriteria(lastResult.breakdown.A, criteriaBreakdownA, "info")
    populateCriteria(lastResult.breakdown.B, criteriaBreakdownB, "secondary")

    // Populate speech reason
    if (resultReason) resultReason.textContent = lastResult.reason || "評審未留下任何評語。"

    // Degradation Mode badge show
    if (lastResult.degraded && degradedBadge) {
      degradedBadge.classList.remove("hidden")
    } else if (degradedBadge) {
      degradedBadge.classList.add("hidden")
    }

    // Role actions
    if (role === "host") {
      hostNextRoundBtn?.classList.remove("hidden")
      playerWaitingBanner?.classList.add("hidden")
    } else {
      hostNextRoundBtn?.classList.add("hidden")
      playerWaitingBanner?.classList.remove("hidden")
    }
  }

  function populateCriteria(breakdown: any, container: HTMLDivElement, colorClass: string) {
    if (!container) return
    container.innerHTML = ""

    const items = [
      { key: "邏輯性（25%）", val: breakdown.logic },
      { key: "符合度（30%）", val: breakdown.relevance },
      { key: "完整性（25%）", val: breakdown.completeness },
      { key: "創意性（20%）", val: breakdown.creativity },
    ]

    for (const item of items) {
      const row = document.createElement("div")
      row.className = "space-y-1"

      row.innerHTML = `
        <div class="flex justify-between items-center text-xs font-bold">
          <span class="text-neutral-content/70">${item.key}</span>
          <span class="text-${colorClass}">${item.val} / 100</span>
        </div>
        <progress class="progress progress-${colorClass} w-full h-2" value="${item.val}" max="100"></progress>
      `

      container.appendChild(row)
    }
  }

  // Next round click trigger
  hostNextRoundBtn?.addEventListener("click", () => {
    socket.emit("match:start", {}, (res: any) => {
      if (!res.ok) {
        alert(`無法開啟新一回合：${res.error}`)
      }
    })
  })

  // ================= RENDER MATCH_OVER =================
  const matchoverWinnerText = document.getElementById("matchover-winner-text") as HTMLHeadingElement
  const backToLobbyBtn = document.getElementById("back-to-lobby-btn") as HTMLButtonElement
  const endGameBtn = document.getElementById("end-game-btn") as HTMLButtonElement
  const matchoverWaitingBanner = document.getElementById(
    "matchover-waiting-banner"
  ) as HTMLDivElement

  function renderMatchOver(state: any) {
    phaseMatchover?.classList.remove("hidden")

    // Determine winner based on score
    const winner = state.score.A > state.score.B ? "藍隊" : "紅隊"
    if (matchoverWinnerText) {
      matchoverWinnerText.textContent = `恭喜${winner}榮登最終霸主`
    }
  }

  function syncGroupLabels(state: any) {
    const matchup = state.currentMatchup ?? state.rounds?.[state.rounds.length - 1]?.matchup
    const groupA = matchup?.groupA ?? 1
    const groupB = matchup?.groupB ?? 2
    headerGroupA.textContent = `第 ${groupA} 組`
    headerGroupB.textContent = `第 ${groupB} 組`
    teamATitle.textContent = `第 ${groupA} 組`
    teamBTitle.textContent = `第 ${groupB} 組`
    resultGroupATitle.textContent = `第 ${groupA} 組`
    resultGroupBTitle.textContent = `第 ${groupB} 組`
    roomInfo.textContent =
      state.matchMode === "test"
        ? `測試場對戰：第 ${groupA} 組 vs 第 ${groupB} 組`
        : `正式場對戰：第 ${groupA} 組 vs 第 ${groupB} 組`
  }

  endGameBtn?.addEventListener("click", () => {
    socket.emit("host:end_game", {}, (res: any) => {
      if (!res.ok) {
        alert(`無法結束本場對戰：${res.error}`)
      }
    })
  })

  liveQuestionsInput?.addEventListener("input", () => (liveQuestionsDirty = true))
  ;[liveRuleIntro, liveRuleTurn, liveRuleResult, liveRuleSeats, liveRuleWins].forEach((el) =>
    el?.addEventListener("input", () => (liveRulesDirty = true))
  )

  liveSaveQuestionsBtn?.addEventListener("click", () => {
    const questions = liveQuestionsInput.value
      .split("\n")
      .map((q) => q.trim())
      .filter(Boolean)
      .slice(0, 200)
    socket.emit("host:set_questions", { questions }, (res: any) => {
      if (!res.ok) setLiveHostStatus(`題庫儲存失敗：${res.error}`, true)
      else {
        liveQuestionsDirty = false
        setLiveHostStatus(`題庫已儲存（${questions.length} 題）`)
      }
    })
  })

  liveSetTopicBtn?.addEventListener("click", () => {
    const topic = liveTopicInput.value.trim()
    if (!topic) return setLiveHostStatus("請先輸入下一題", true)
    socket.emit("host:set_topic", { topic }, (res: any) => {
      if (!res.ok) setLiveHostStatus(`指定題目失敗：${res.error}`, true)
      else setLiveHostStatus("下一題已指定")
    })
  })

  hostForceEndGameBtn?.addEventListener("click", () => {
    const confirmed = confirm("確認要直接結束這一組遊戲嗎？目前進度將不再繼續。")
    if (!confirmed) return
    socket.emit("host:force_end_game", {}, (res: any) => {
      if (!res.ok) setLiveHostStatus(`無法強制結束本組：${res.error}`, true)
      else setLiveHostStatus("已強制結束這一組遊戲")
    })
  })

  liveRandomTopicBtn?.addEventListener("click", () => {
    socket.emit("host:set_topic", { random: true }, (res: any) => {
      if (!res.ok) setLiveHostStatus(`隨機題目失敗：${res.error}`, true)
      else setLiveHostStatus("已從題庫隨機選題")
    })
  })

  liveSaveRulesBtn?.addEventListener("click", () => {
    const payload: Record<string, number> = {}
    const addMs = (key: string, input: HTMLInputElement) => {
      const n = Number(input.value)
      if (!Number.isNaN(n)) payload[key] = Math.round(n * 1000)
    }
    addMs("introMs", liveRuleIntro)
    addMs("turnMs", liveRuleTurn)
    addMs("resultMs", liveRuleResult)
    const seats = Number(liveRuleSeats.value)
    const wins = Number(liveRuleWins.value)
    if (!Number.isNaN(seats)) payload.seats = Math.round(seats)
    if (!Number.isNaN(wins)) payload.winsToTakeMatch = Math.round(wins)
    socket.emit("host:set_rules", payload, (res: any) => {
      if (!res.ok) setLiveHostStatus(`規則套用失敗：${res.error}`, true)
      else {
        liveRulesDirty = false
        setLiveHostStatus("規則已套用")
      }
    })
  })

  function syncLiveHostForm(state: any) {
    if (role !== "host") return
    if (!liveQuestionsDirty && liveQuestionsInput)
      liveQuestionsInput.value = (state.questions ?? []).join("\n")
    if (!liveRulesDirty && state.rules) {
      liveRuleIntro.value = String(Math.round(state.rules.introMs / 1000))
      liveRuleTurn.value = String(Math.round(state.rules.turnMs / 1000))
      liveRuleResult.value = String(Math.round(state.rules.resultMs / 1000))
      liveRuleSeats.value = String(state.rules.seats)
      liveRuleWins.value = String(state.rules.winsToTakeMatch)
    }
    if (liveNextTopicLabel) {
      liveNextTopicLabel.textContent = state.nextTopic
        ? `下一題：${state.nextTopic}`
        : "未指定下一題"
    }
  }

  function setLiveHostStatus(message: string, isError = false) {
    if (!hostLiveStatus) return
    hostLiveStatus.textContent = message
    hostLiveStatus.className = isError
      ? "text-error min-h-[1.25rem] text-xs font-bold"
      : "text-success min-h-[1.25rem] text-xs font-bold"
  }

  // ================= HOST CONTROL ACTIONS EVENT LISTENERS =================
  hostPauseBtn?.addEventListener("click", () => {
    socket.emit("host:pause", {}, (res: any) => {
      if (!res.ok) alert(`暫停失敗：${res.error}`)
    })
  })

  hostResumeBtn?.addEventListener("click", () => {
    socket.emit("host:resume", {}, (res: any) => {
      if (!res.ok) alert(`恢復失敗：${res.error}`)
    })
  })

  hostForceJudgeBtn?.addEventListener("click", () => {
    if (confirm("確認強制提早結束本回合，直接進入 AI 評審打分階段嗎？")) {
      socket.emit("host:force_judge", {}, (res: any) => {
        if (!res.ok) alert(`操作失敗：${res.error}`)
      })
    }
  })

  skipTeamABtn?.addEventListener("click", () => {
    if (confirm("確認強制超時並跳過 A 小隊當前棒次嗎？")) {
      socket.emit("host:skip_turn", { team: "A" }, (res: any) => {
        if (!res.ok) alert(`操作失敗：${res.error}`)
      })
    }
  })

  skipTeamBBtn?.addEventListener("click", () => {
    if (confirm("確認強制超時並跳過 B 小隊當前棒次嗎？")) {
      socket.emit("host:skip_turn", { team: "B" }, (res: any) => {
        if (!res.ok) alert(`操作失敗：${res.error}`)
      })
    }
  })

  backToLobbyBtn?.addEventListener("click", () => {
    clearSession()
    sessionStorage.clear()
    window.location.href = "/"
  })
</script>
