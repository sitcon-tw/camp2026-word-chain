# Copy to .env. The ONLY value you normally need to set is OPENAI_API_KEY.
# Game rules (timings / 段數 / 勝場) and questions are configured by the host
# in the admin panel at runtime, not here. Leave the rest on their defaults.

# --- Required ---
OPENAI_API_KEY=

# --- Optional (sensible defaults) ---
# OPENAI_MODEL=gpt-5.5
# PORT=3001
# CORS_ORIGIN=http://localhost:4321
# REDIS_URL=redis://127.0.0.1:6379

# Default rules a new room starts with (host can override live in the panel).
# INTRO_MS=30000
# RESULT_MS=30000
